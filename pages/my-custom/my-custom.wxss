.container {
  min-height: 100vh;
  background: #f8fafc;
  padding-bottom: 200rpx;
}

.header-tip {
  padding: 24rpx 32rpx;
  font-size: 24rpx;
  color: #64748b;
  background: #eff6ff;
  border-bottom: 1rpx solid #dbeafe;
}

.tip-text { display: block; }

.card {
  background: #ffffff;
  margin: 24rpx 24rpx 0;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.card-title {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 24rpx;
}

.card-title text:first-child {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

.card-sub { font-size: 22rpx; color: #94a3b8; }

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: #eff6ff;
  color: #1e88ff;
  border-radius: 32rpx;
  font-size: 26rpx;
}

.tag-close {
  width: 28rpx;
  height: 28rpx;
  line-height: 24rpx;
  text-align: center;
  background: rgba(30, 136, 255, 0.15);
  border-radius: 50%;
  font-size: 24rpx;
}

.tag-add {
  padding: 12rpx 24rpx;
  background: #f1f5f9;
  color: #64748b;
  border-radius: 32rpx;
  font-size: 26rpx;
  border: 2rpx dashed #cbd5e1;
}

.region-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.region-chip {
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  background: #f1f5f9;
  color: #475569;
  border-radius: 32rpx;
  border: 2rpx solid transparent;
}

.region-chip.active {
  background: #eff6ff;
  color: #1e88ff;
  border-color: #1e88ff;
  font-weight: 500;
}

.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.setting-row:last-child { border-bottom: none; }

.setting-label {
  font-size: 28rpx;
  color: #1e293b;
}

.save-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx 48rpx;
  background: #ffffff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.save-btn {
  background: linear-gradient(135deg, #1e88ff 0%, #42a5f5 100%);
  color: #ffffff;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  padding: 24rpx 0;
  border-radius: 48rpx;
  box-shadow: 0 4rpx 12rpx rgba(30, 136, 255, 0.3);
}
