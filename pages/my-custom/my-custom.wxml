<view class="container">
  <!-- 顶部说明 -->
  <view class="header-tip">
    <text class="tip-text">订阅规则后，符合条件的招标将实时推送给您</text>
  </view>

  <!-- 关键词订阅 -->
  <view class="card">
    <view class="card-title">
      <text>关键词订阅</text>
      <text class="card-sub">最多 10 个</text>
    </view>
    <view class="tag-list">
      <view class="tag-item" wx:for="{{keywords}}" wx:key="value" bindtap="onRemoveKeyword" data-value="{{item.value}}">
        <text class="tag-text">{{item.value}}</text>
        <text class="tag-close">×</text>
      </view>
      <view class="tag-add" bindtap="onAddKeyword">
        <text>+ 添加关键词</text>
      </view>
    </view>
  </view>

  <!-- 地区订阅 -->
  <view class="card">
    <view class="card-title">
      <text>地区订阅</text>
      <text class="card-sub">已选 {{regions.length}} 个</text>
    </view>
    <view class="region-list">
      <view class="region-chip {{selectedRegions.includes(item) ? 'active' : ''}}"
            wx:for="{{allRegions}}" wx:key="*this"
            bindtap="onToggleRegion" data-region="{{item}}">
        {{item}}
      </view>
    </view>
  </view>

  <!-- 类型订阅 -->
  <view class="card">
    <view class="card-title">
      <text>信息类型</text>
    </view>
    <view class="region-list">
      <view class="region-chip {{settings.bidType === item.value ? 'active' : ''}}"
            wx:for="{{allTypes}}" wx:key="value"
            bindtap="onSelectType" data-value="{{item.value}}">
        {{item.label}}
      </view>
    </view>
  </view>

  <!-- 推送方式 -->
  <view class="card">
    <view class="card-title"><text>推送方式</text></view>
    <view class="setting-row">
      <text class="setting-label">应用内通知</text>
      <switch checked="{{settings.pushSwitch}}" bindchange="onSwitchChange" data-key="pushSwitch" color="#1e88ff"/>
    </view>
    <view class="setting-row">
      <text class="setting-label">招标通知</text>
      <switch checked="{{settings.notifyBid}}" bindchange="onSwitchChange" data-key="notifyBid" color="#1e88ff"/>
    </view>
    <view class="setting-row">
      <text class="setting-label">中标通知</text>
      <switch checked="{{settings.notifyWin}}" bindchange="onSwitchChange" data-key="notifyWin" color="#1e88ff"/>
    </view>
    <view class="setting-row">
      <text class="setting-label">邮件通知</text>
      <switch checked="{{settings.emailNotify}}" bindchange="onSwitchChange" data-key="emailNotify" color="#1e88ff"/>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="save-bar">
    <view class="save-btn" bindtap="onSave">保存设置</view>
  </view>
</view>
