.container {
  min-height: 100vh;
  background: #f8fafc;
  padding-bottom: 40rpx;
}

/* 顶部导航 */
.header {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 32rpx;
  background: #1e88ff;
  color: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.back-btn {
  font-size: 56rpx;
  line-height: 1;
  width: 60rpx;
  text-align: left;
  margin-right: 16rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  flex: 1;
}

/* 列表 */
.list {
  padding: 24rpx 24rpx 0;
}

/* 订单卡片 */
.order-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.package-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  flex: 1;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.status-tag {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-left: 16rpx;
}

.status-pending  { background: #fef3c7; color: #d97706; }
.status-paid     { background: #dcfce7; color: #16a34a; }
.status-closed   { background: #f1f5f9; color: #64748b; }
.status-refunded { background: #fee2e2; color: #dc2626; }
.status-unknown  { background: #f1f5f9; color: #64748b; }

.card-mid {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-top: 2rpx solid #f1f5f9;
  border-bottom: 2rpx solid #f1f5f9;
}

.amount-box {
  display: flex;
  align-items: baseline;
}

.amount-symbol {
  font-size: 26rpx;
  color: #1e88ff;
  font-weight: 600;
}

.amount-num {
  font-size: 44rpx;
  color: #1e88ff;
  font-weight: 700;
  margin-left: 4rpx;
}

.points-box {
  display: flex;
  align-items: baseline;
}

.points-num {
  font-size: 36rpx;
  color: #f97316;
  font-weight: 700;
}

.points-label {
  font-size: 24rpx;
  color: #94a3b8;
  margin-left: 6rpx;
}

.card-bot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.order-no {
  font-size: 22rpx;
  color: #94a3b8;
  flex: 1;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.order-time {
  font-size: 22rpx;
  color: #94a3b8;
  margin-left: 16rpx;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #94a3b8;
}

/* 加载提示 */
.loading {
  text-align: center;
  padding: 32rpx 0;
  font-size: 24rpx;
  color: #94a3b8;
}
