<view class="container">
  <view class="header" style="padding-top: {{statusBarHeight}}px;">
    <view class="back-btn" bindtap="onBackTap">‹</view>
    <view class="header-title">购买记录</view>
  </view>

  <view class="list">
    <view wx:if="{{list.length === 0 && !loading}}" class="empty">
      <view class="empty-icon">🧾</view>
      <view class="empty-text">暂无购买记录</view>
    </view>

    <view class="order-card" wx:for="{{list}}" wx:key="order_no">
      <!-- 顶部：套餐名 + 状态标签 -->
      <view class="card-top">
        <text class="package-name">{{item.packageName || '积分套餐'}}</text>
        <text class="status-tag status-{{item.statusKey}}">{{item.statusText}}</text>
      </view>

      <!-- 中部：金额 + 积分（仅已支付显示积分） -->
      <view class="card-mid">
        <view class="amount-box">
          <text class="amount-symbol">¥</text>
          <text class="amount-num">{{item.yuan}}</text>
        </view>
        <view class="points-box" wx:if="{{item.showPoints}}">
          <text class="points-num">+{{item.pointsTotal}}</text>
          <text class="points-label">积分</text>
        </view>
      </view>

      <!-- 底部：订单号 + 时间 -->
      <view class="card-bot">
        <text class="order-no">订单号：{{item.orderNo}}</text>
        <text class="order-time">{{item.timeText}}</text>
      </view>
    </view>
  </view>

  <view class="loading" wx:if="{{loading}}">加载中…</view>
  <view class="loading" wx:elif="{{!hasMore && list.length > 0}}">— 已加载全部 —</view>
</view>
