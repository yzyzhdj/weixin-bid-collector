.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}
.header {
  background: linear-gradient(135deg, #1e88ff 0%, #1565c0 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}
.back-btn {
  font-size: 60rpx;
  width: 60rpx;
  line-height: 60rpx;
  text-align: center;
  color: #ffffff;
}
.header-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  margin-right: 60rpx;
}
.list {
  padding: 24rpx;
}
.list-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.item-title {
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 500;
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.item-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 12rpx;
}
.meta-tag {
  background: #e0f2fe;
  color: #0369a1;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
}
.meta-company {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.item-foot {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #94a3b8;
}
.item-remark {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #e2e8f0;
  font-size: 24rpx;
  color: #475569;
}
.empty {
  text-align: center;
  padding: 200rpx 32rpx;
}
.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}
.empty-text {
  font-size: 30rpx;
  color: #475569;
  margin-bottom: 12rpx;
}
.empty-hint {
  font-size: 24rpx;
  color: #94a3b8;
}
.loading {
  text-align: center;
  padding: 32rpx;
  color: #94a3b8;
  font-size: 24rpx;
}
