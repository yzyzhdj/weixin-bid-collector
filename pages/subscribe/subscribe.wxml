<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="header-content">
      <view class="header-title">订阅</view>
    </view>
  </view>

  <!-- 切换 Tab -->
  <view class="tabs">
    <view class="tab {{activeTab === 'keyword' ? 'active' : ''}}" bindtap="switchTab" data-tab="keyword">关键词订阅</view>
    <view class="tab {{activeTab === 'company' ? 'active' : ''}}" bindtap="switchTab" data-tab="company">企业订阅</view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state">
    <image class="empty-illustration" src="/images/subscribe-empty.svg" mode="aspectFit"></image>
    <text class="empty-text">您还没有相关订阅哦,快去订阅吧!</text>
    <view class="subscribe-btn" bindtap="onSubscribe">立即订阅</view>
  </view>

  <!-- 悬浮添加按钮 -->
  <view class="fab" bindtap="onAdd">
    <text class="fab-icon">+</text>
    <text class="fab-text">添加</text>
  </view>
</view>
