.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 60rpx;
}

/* 顶部企业名卡片 */
.header-card {
  background: #ffffff;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f1f5f9;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.header-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  line-height: 1.4;
}

/* 列表 */
.list {
  padding: 20rpx 32rpx;
}

/* 标讯条目（时间线样式） */
.bid-item {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 24rpx 24rpx;
  position: relative;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: opacity 0.15s;
}

.bid-item:active {
  opacity: 0.75;
  background: #f8fafc;
}

/* 左侧时间线 */
.bid-timeline {
  position: relative;
  width: 32rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
  padding-top: 8rpx;
}

.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #cbd5e1;
  border: 4rpx solid #ffffff;
  box-shadow: 0 0 0 2rpx #cbd5e1;
  margin: 0 auto;
}

.timeline-line {
  position: absolute;
  top: 28rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 2rpx;
  height: calc(100% - 8rpx);
  background: #e2e8f0;
}

/* 右侧标讯内容 */
.bid-body {
  flex: 1;
  min-width: 0;
}

.bid-time {
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 8rpx;
}

.bid-title {
  font-size: 28rpx;
  color: #1e88ff;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: break-all;
}

/* 加载提示 */
.load-tip {
  text-align: center;
  font-size: 24rpx;
  color: #94a3b8;
  padding: 24rpx 0;
}

/* 空状态 */
.empty {
  padding: 120rpx 0;
  text-align: center;
  color: #94a3b8;
  font-size: 28rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 60rpx 0;
  color: #94a3b8;
  font-size: 26rpx;
}
