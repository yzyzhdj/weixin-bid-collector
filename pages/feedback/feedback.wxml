<view class="container">
  <view class="form">
    <view class="form-title">您的意见对我们非常重要</view>
    <view class="form-sub">我们会认真阅读每一条反馈</view>

    <!-- 类型 -->
    <view class="form-row">
      <text class="form-label">反馈类型</text>
      <view class="type-list">
        <view class="type-chip {{form.type === item.value ? 'active' : ''}}"
              wx:for="{{types}}" wx:key="value"
              bindtap="onTypeTap" data-value="{{item.value}}">
          {{item.label}}
        </view>
      </view>
    </view>

    <!-- 反馈内容 -->
    <view class="form-row">
      <text class="form-label">详细描述</text>
      <textarea class="form-textarea" placeholder="请描述您遇到的问题或建议（最少 10 字）"
                maxlength="500" bindinput="onContentInput" value="{{form.content}}"></textarea>
      <view class="form-counter">{{form.content.length}}/500</view>
    </view>

    <!-- 联系方式 -->
    <view class="form-row">
      <text class="form-label">联系方式（选填）</text>
      <input class="form-input" placeholder="手机号或微信号" value="{{form.contact}}" bindinput="onContactInput"/>
    </view>
  </view>

  <view class="submit-bar">
    <view class="submit-btn {{canSubmit ? '' : 'disabled'}}" bindtap="onSubmit">提交反馈</view>
  </view>
</view>
