.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 180rpx;
}

/* 蓝色 header */
.header {
  position: relative;
  width: 100%;
  height: 260rpx;
  background: linear-gradient(135deg, #1e88ff 0%, #4facfe 50%, #6fb1fc 100%);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    radial-gradient(circle at 80% 20%, rgba(255, 255, 255, 0.15) 0%, transparent 40%),
    radial-gradient(circle at 20% 80%, rgba(255, 255, 255, 0.1) 0%, transparent 40%);
}

.header-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-title {
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  line-height: 1.4;
}

.header-subtitle {
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
  margin-top: 16rpx;
  line-height: 1.4;
}

/* 表单卡片 */
.form-card {
  background: #fff;
  margin: 24rpx 24rpx 0;
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.form-row-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.form-label {
  color: #1f2937;
  font-size: 30rpx;
  font-weight: 600;
}

.form-counter {
  color: #94a3b8;
  font-size: 24rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  color: #1f2937;
  line-height: 80rpx;
  padding: 0;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 320rpx;
  font-size: 28rpx;
  color: #1f2937;
  line-height: 1.6;
  padding: 0;
  box-sizing: border-box;
}

.form-placeholder {
  color: #cbd5e1;
  font-size: 28rpx;
}

.form-divider {
  height: 1rpx;
  background: #f1f5f9;
  margin: 24rpx 0;
}

/* 底部固定提交按钮 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.footer-btn {
  text-align: center;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.2s;
}

.footer-btn.active {
  background: linear-gradient(135deg, #1e88ff 0%, #4facfe 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(30, 136, 255, 0.3);
}

.footer-btn.disabled {
  background: #cbd5e1;
  color: #fff;
  box-shadow: none;
}
