.container {
  min-height: 100vh;
  background: #f8fafc;
  padding-bottom: 200rpx;
}

.form {
  background: #ffffff;
  margin: 24rpx 24rpx 0;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.form-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1e293b;
  text-align: center;
}

.form-sub {
  font-size: 26rpx;
  color: #94a3b8;
  text-align: center;
  margin-top: 12rpx;
  margin-bottom: 32rpx;
}

.form-row {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.type-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.type-chip {
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  background: #f1f5f9;
  color: #475569;
  border-radius: 32rpx;
  border: 2rpx solid transparent;
}

.type-chip.active {
  background: #eff6ff;
  color: #1e88ff;
  border-color: #1e88ff;
  font-weight: 500;
}

.form-textarea {
  width: 100%;
  height: 240rpx;
  padding: 24rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1e293b;
  box-sizing: border-box;
}

.form-counter {
  text-align: right;
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 8rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1e293b;
  box-sizing: border-box;
}

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx 48rpx;
  background: #ffffff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.submit-btn {
  background: linear-gradient(135deg, #1e88ff 0%, #42a5f5 100%);
  color: #ffffff;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  padding: 24rpx 0;
  border-radius: 48rpx;
  box-shadow: 0 4rpx 12rpx rgba(30, 136, 255, 0.3);
}

.submit-btn.disabled {
  background: #cbd5e1;
  box-shadow: none;
}
