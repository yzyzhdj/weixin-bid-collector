.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}
.header {
  background: linear-gradient(135deg, #1e88ff 0%, #1565c0 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}
.back-btn {
  font-size: 60rpx;
  width: 60rpx;
  line-height: 60rpx;
  text-align: center;
  color: #ffffff;
}
.header-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
}
.mark-btn {
  font-size: 26rpx;
  color: #ffffff;
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
}
.list {
  padding: 24rpx;
}
.list-item {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.item-dot {
  width: 16rpx;
  height: 16rpx;
  background: #ef4444;
  border-radius: 50%;
  margin-top: 14rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.item-body {
  flex: 1;
  min-width: 0;
}
.item-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.item-title {
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 500;
  flex: 1;
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.item-title.unread {
  color: #0c4a6e;
  font-weight: 600;
}
.item-time {
  font-size: 22rpx;
  color: #94a3b8;
  flex-shrink: 0;
}
.item-content {
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.empty {
  text-align: center;
  padding: 200rpx 32rpx;
}
.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}
.empty-text {
  font-size: 30rpx;
  color: #475569;
}
.loading {
  text-align: center;
  padding: 32rpx;
  color: #94a3b8;
  font-size: 24rpx;
}
