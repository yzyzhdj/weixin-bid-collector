.container {
  min-height: 100vh;
  background: #f8fafc;
  padding-bottom: 40rpx;
}

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f1f5f9;
}

.top-tip { font-size: 24rpx; color: #64748b; }

.top-action {
  font-size: 26rpx;
  color: #1e88ff;
  padding: 8rpx 20rpx;
  background: #eff6ff;
  border-radius: 24rpx;
}

.list { padding: 16rpx 24rpx; }

.item {
  position: relative;
  display: flex;
  align-items: flex-start;
  background: #ffffff;
  padding: 28rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.item.unread {
  background: linear-gradient(to right, #eff6ff 0%, #ffffff 30%);
}

.item-dot {
  position: absolute;
  top: 28rpx;
  right: 24rpx;
  width: 16rpx;
  height: 16rpx;
  background: #ef4444;
  border-radius: 50%;
}

.item-type {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: #f1f5f9;
  color: #64748b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.item-type.system { background: #eff6ff; color: #1e88ff; }
.item-type.bid    { background: #fef3c7; color: #d97706; }
.item-type.review { background: #f3e8ff; color: #9333ea; }
.item-type.message{ background: #d1fae5; color: #059669; }

.item-main { flex: 1; min-width: 0; }

.item-title {
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 500;
}

.item-content {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-time {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 48rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 96rpx;
  margin-bottom: 32rpx;
}

.empty-title { font-size: 32rpx; color: #475569; font-weight: 500; }
.empty-sub { font-size: 26rpx; color: #94a3b8; margin-top: 12rpx; }
