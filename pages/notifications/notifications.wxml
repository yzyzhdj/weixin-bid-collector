<view class="container">
  <view class="top-bar" wx:if="{{notifications.length > 0}}">
    <text class="top-tip">共 {{notifications.length}} 条，{{unreadCount}} 条未读</text>
    <view class="top-action" bindtap="onMarkAll">全部已读</view>
  </view>

  <view class="list" wx:if="{{notifications.length > 0}}">
    <view class="item {{item.isRead ? '' : 'unread'}}" wx:for="{{notifications}}" wx:key="id" bindtap="onItemTap" data-id="{{item.id}}">
      <view class="item-dot" wx:if="{{!item.isRead}}"></view>
      <view class="item-type {{item.type}}">
        <text wx:if="{{item.type === 'system'}}">系</text>
        <text wx:elif="{{item.type === 'bid'}}">标</text>
        <text wx:elif="{{item.type === 'review'}}">审</text>
        <text wx:else>信</text>
      </view>
      <view class="item-main">
        <view class="item-title">{{item.title}}</view>
        <view class="item-content">{{item.content}}</view>
        <view class="item-time">{{item.timeText}}</view>
      </view>
    </view>
  </view>

  <view class="empty" wx:else>
    <view class="empty-icon"><text>🔔</text></view>
    <view class="empty-title">暂无消息</view>
    <view class="empty-sub">订阅和系统消息会显示在这里</view>
  </view>
</view>
