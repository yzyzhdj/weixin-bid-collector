.container {
  padding-bottom: 140rpx;
  background: #f8fafc;
  min-height: 100vh;
}

.detail-header {
  background: #ffffff;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.detail-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1e293b;
  line-height: 1.5;
  margin-bottom: 24rpx;
}

.detail-meta {
  display: flex;
  gap: 32rpx;
}

.meta-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.meta-label {
  font-size: 24rpx;
  color: #94a3b8;
}

.meta-value {
  font-size: 28rpx;
  color: #475569;
}

.detail-section {
  background: #ffffff;
  margin-bottom: 24rpx;
  padding: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #2563eb;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.info-label {
  font-size: 28rpx;
  color: #64748b;
  flex-shrink: 0;
  width: 160rpx;
}

.info-value {
  font-size: 28rpx;
  color: #334155;
  text-align: right;
  flex: 1;
  word-break: break-all;
}

.info-value.highlight {
  color: #dc2626;
  font-weight: 600;
}

.content-text {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.8;
  white-space: pre-wrap;
}

.related-item {
  padding: 24rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.related-item:last-child {
  margin-bottom: 0;
}

.related-title {
  font-size: 28rpx;
  color: #1e293b;
  margin-bottom: 12rpx;
}

.related-meta {
  display: flex;
  gap: 24rpx;
  font-size: 24rpx;
  color: #64748b;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  margin-right: 48rpx;
}

.bar-icon {
  width: 40rpx;
  height: 40rpx;
}

.bar-item text {
  font-size: 22rpx;
  color: #64748b;
}

.bar-btn {
  margin-left: auto;
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  color: #ffffff;
  padding: 24rpx 60rpx;
  border-radius: 60rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.loading {
  text-align: center;
  padding: 100rpx;
  color: #94a3b8;
  font-size: 28rpx;
}
