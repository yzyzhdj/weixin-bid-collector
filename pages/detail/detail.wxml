<view class="container" wx:if="{{detail}}">
  <view class="detail-header">
    <view class="detail-title">{{detail.title}}</view>
    <view class="detail-meta">
      <view class="meta-item">
        <text class="meta-label">公告类型</text>
        <text class="meta-value">{{detail.bidType || '-'}}</text>
      </view>
      <view class="meta-item">
        <text class="meta-label">发布时间</text>
        <text class="meta-value">{{detail.publishDate}}</text>
      </view>
    </view>
  </view>

  <view class="detail-section">
    <view class="section-title">基本信息</view>
    <view class="info-list">
      <view class="info-item" wx:if="{{detail.source}}">
        <text class="info-label">数据来源</text>
        <text class="info-value">{{detail.source}}</text>
      </view>
      <view class="info-item" wx:if="{{detail.biddingMethod}}">
        <text class="info-label">招标方式</text>
        <text class="info-value">{{detail.biddingMethod}}</text>
      </view>
      <view class="info-item" wx:if="{{detail.budget}}">
        <text class="info-label">预算金额</text>
        <text class="info-value highlight">{{detail.budget}}</text>
      </view>
      <view class="info-item" wx:if="{{detail.province || detail.city}}">
        <text class="info-label">地区</text>
        <text class="info-value">{{detail.province || ''}}{{detail.city || ''}}</text>
      </view>
      <view class="info-item" wx:if="{{detail.deadline}}">
        <text class="info-label">投标截止</text>
        <text class="info-value">{{detail.deadline}}</text>
      </view>
      <view class="info-item" wx:if="{{detail.buyer}}">
        <text class="info-label">采购单位</text>
        <text class="info-value">{{detail.buyer}}</text>
      </view>
      <view class="info-item" wx:if="{{detail.buyerContact}}">
        <text class="info-label">采购联系</text>
        <text class="info-value">{{detail.buyerContact}}</text>
      </view>
      <view class="info-item" wx:if="{{detail.agent}}">
        <text class="info-label">代理机构</text>
        <text class="info-value">{{detail.agent}}</text>
      </view>
      <view class="info-item" wx:if="{{detail.agentContact}}">
        <text class="info-label">代理联系</text>
        <text class="info-value">{{detail.agentContact}}</text>
      </view>
      <view class="info-item" wx:if="{{detail.supervisor}}">
        <text class="info-label">监管部门</text>
        <text class="info-value">{{detail.supervisor}}</text>
      </view>
      <view class="info-item" wx:if="{{detail.openBidTime}}">
        <text class="info-label">开标时间</text>
        <text class="info-value">{{detail.openBidTime}}</text>
      </view>
      <view class="info-item" wx:if="{{detail.noticeNature}}">
        <text class="info-label">公告性质</text>
        <text class="info-value">{{detail.noticeNature}}</text>
      </view>
    </view>
  </view>

  <view class="detail-section" wx:if="{{detail.winner}}">
    <view class="section-title">中标信息</view>
    <view class="info-list">
      <view class="info-item">
        <text class="info-label">中标供应商</text>
        <text class="info-value highlight">{{detail.winner}}</text>
      </view>
      <view class="info-item" wx:if="{{detail.winAmount}}">
        <text class="info-label">中标金额</text>
        <text class="info-value highlight">{{detail.winAmount}}</text>
      </view>
    </view>
  </view>

  <view class="detail-section" wx:if="{{detail.content}}">
    <view class="section-title">公告内容</view>
    <view class="content-text">{{detail.content}}</view>
  </view>

  <view class="detail-section" wx:if="{{detail.sections && detail.sections.length > 0}}">
    <view class="section-title">标段信息</view>
    <view class="related-item" wx:for="{{detail.sections}}" wx:key="id">
      <view class="related-title">{{item.sectionName || '标段' + item.id}}</view>
      <view class="related-meta">
        <text wx:if="{{item.estimatedPrice}}">{{item.estimatedPrice}}</text>
        <text wx:if="{{item.sectionCategory}}">{{item.sectionCategory}}</text>
      </view>
    </view>
  </view>

  <view class="detail-section" wx:if="{{detail.attachments && detail.attachments.length > 0}}">
    <view class="section-title">附件下载</view>
    <view class="related-item" wx:for="{{detail.attachments}}" wx:key="id">
      <view class="related-title">{{item.fileName}}</view>
      <view class="related-meta">
        <text wx:if="{{item.fileType}}">{{item.fileType}}</text>
        <text wx:if="{{item.fileSize}}">{{item.fileSize}} 字节</text>
      </view>
    </view>
  </view>

  <view class="detail-section" wx:if="{{detail.parentBid}}">
    <view class="section-title">关联招标公告</view>
    <view class="related-item">
      <view class="related-title">{{detail.parentBid.title}}</view>
      <view class="related-meta">
        <text>{{detail.parentBid.bidType}}</text>
        <text>{{detail.parentBid.publishDateFmt || detail.parentBid.publishDate}}</text>
      </view>
    </view>
  </view>

  <view class="detail-section" wx:if="{{detail.childBids && detail.childBids.length > 0}}">
    <view class="section-title">关联中标公告</view>
    <view class="related-item" wx:for="{{detail.childBids}}" wx:key="id">
      <view class="related-title">{{item.title}}</view>
      <view class="related-meta">
        <text>{{item.bidType}}</text>
        <text wx:if="{{item.winAmount}}">{{item.winAmount}}</text>
      </view>
    </view>
  </view>

  <view class="bottom-bar">
    <view class="bar-item" bindtap="onCollect">
      <image class="bar-icon" src="/images/icon-collect.png" mode="aspectFit"></image>
      <text>收藏</text>
    </view>
    <view class="bar-item" bindtap="onShare">
      <image class="bar-icon" src="/images/icon-share.png" mode="aspectFit"></image>
      <text>分享</text>
    </view>
    <view class="bar-btn" bindtap="onSubscribe">
      <text>立即订阅</text>
    </view>
  </view>
</view>

<view class="loading" wx:if="{{loading}}">
  <text>加载中...</text>
</view>
