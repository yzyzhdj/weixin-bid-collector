.container {
  padding: 0;
  background: #f5f7fa;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.header {
  background: #ffffff;
  padding: 0 32rpx 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
  /* 兼容 iOS 11.2 以下 */
  padding-top: constant(safe-area-inset-top);
  /* iOS 11.2+ / 安卓全面屏 */
  padding-top: env(safe-area-inset-top);
}

.status-bar {
  width: 100%;
  /* 高度由 JS 动态设置，适配刘海屏 */
}

.header-title {
  font-size: 36rpx;
  color: #1e293b;
  font-weight: 700;
  text-align: center;
  letter-spacing: 2rpx;
}

.section {
  background: #ffffff;
  margin-top: 20rpx;
  padding: 32rpx 24rpx;
}

.section-title {
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 700;
  margin-bottom: 32rpx;
  letter-spacing: 1rpx;
}

.grid {
  display: grid;
  gap: 32rpx 0;
}

.grid-2 {
  grid-template-columns: repeat(2, 1fr);
}

.grid-3 {
  grid-template-columns: repeat(3, 1fr);
}

.grid-4 {
  grid-template-columns: repeat(4, 1fr);
}

.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  transition: transform 0.2s ease;
}

.grid-item:active {
  transform: scale(0.95);
}

.grid-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.grid-icon {
  width: 56rpx;
  height: 56rpx;
}

.grid-name {
  font-size: 26rpx;
  color: #334155;
  text-align: center;
}

.grid-badge {
  position: absolute;
  top: -8rpx;
  right: -16rpx;
  font-size: 18rpx;
  color: #ffffff;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  font-weight: 600;
  line-height: 1.2;
  white-space: nowrap;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
}

.grid-badge.badge-red {
  background: linear-gradient(135deg, #f87171 0%, #ef4444 100%);
}

.grid-badge.badge-orange {
  background: linear-gradient(135deg, #fb923c 0%, #f97316 100%);
}

/* 标书模版 2列 */
