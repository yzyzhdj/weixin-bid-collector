.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
  overflow-x: hidden;
}

/* ========== 头部 ========== */
.header {
  background: #ffffff;
  padding: calc(24rpx + env(safe-area-inset-top)) 32rpx 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.header-title {
  font-size: 34rpx;
  color: #1e293b;
  font-weight: 600;
  text-align: center;
  letter-spacing: 2rpx;
}

/* ========== 内容区 ========== */
.content-wrap {
  padding: 0 24rpx;
}

/* ========== 分组卡片 ========== */
.section-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx 20rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-hd {
  padding: 0 12rpx 24rpx;
}

.card-title {
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 600;
  letter-spacing: 1rpx;
  position: relative;
  padding-left: 20rpx;
}

.card-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 28rpx;
  background: linear-gradient(180deg, #1e88ff 0%, #4facfe 100%);
  border-radius: 4rpx;
}

/* ========== 宫格网格 ========== */
.grid {
  display: flex;
  flex-wrap: wrap;
}

.grid-3 .grid-item {
  width: 33.33%;
}

.grid-4 .grid-item {
  width: 25%;
}

.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 8rpx;
  box-sizing: border-box;
  min-width: 0;
}

.grid-item:active .icon-box {
  transform: scale(0.92);
}

/* ========== 图标方块（与首页四菜单同规格） ========== */
.icon-box {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.15s ease;
}

.icon-img {
  width: 56rpx;
  height: 56rpx;
}

.icon-label {
  font-size: 24rpx;
  color: #334155;
  margin-top: 16rpx;
  text-align: center;
  line-height: 1.3;
}

/* ========== 红点徽标 ========== */
.icon-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  font-size: 18rpx;
  color: #ffffff;
  padding: 0 8rpx;
  border-radius: 16rpx;
  font-weight: 600;
  background: #ef4444;
  box-shadow: 0 2rpx 6rpx rgba(239, 68, 68, 0.3);
  box-sizing: border-box;
}
