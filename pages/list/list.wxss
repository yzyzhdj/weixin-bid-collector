.container {
  padding-bottom: 20rpx;
  background: #f8fafc;
  min-height: 100vh;
}

.top-tabs {
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  padding: 32rpx;
  display: flex;
  gap: 40rpx;
  overflow-x: auto;
}

.top-tab {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.7);
  padding: 8rpx 0;
  white-space: nowrap;
  position: relative;
}

.top-tab.active {
  color: #ffffff;
  font-weight: 600;
}

.top-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 4rpx;
  background: #ffffff;
  border-radius: 2rpx;
}

.filter-bar {
  background: #ffffff;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.filter-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #475569;
}

.arrow-down {
  width: 24rpx;
  height: 24rpx;
}

.filter-btn {
  margin-left: auto;
  border: 1rpx solid #2563eb;
  color: #2563eb;
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
}

.result-info {
  padding: 24rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.result-info text {
  font-size: 28rpx;
  color: #475569;
}

.export-btn {
  color: #2563eb;
  font-size: 26rpx;
}

.ad-banner {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  margin: 0 32rpx 24rpx;
  padding: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.ad-left {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ad-tag {
  background: #dc2626;
  color: #ffffff;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.ad-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.ad-text {
  font-size: 28rpx;
  color: #92400e;
  font-weight: 500;
}

.ad-btn {
  background: #dc2626;
  color: #ffffff;
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
}

.bid-list {
  padding: 0 32rpx;
}

.bid-item {
  background: #ffffff;
  padding: 32rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.bid-title {
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 500;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.bid-meta {
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 20rpx;
}

.bid-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.bid-type {
  background: #eff6ff;
  color: #1e40af;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.bid-date {
  font-size: 26rpx;
  color: #94a3b8;
}

.template-section {
  padding: 32rpx;
}

.template-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.template-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.template-more {
  font-size: 26rpx;
  color: #64748b;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #94a3b8;
  font-size: 28rpx;
}
