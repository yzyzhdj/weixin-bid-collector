<view class="container">
  <view class="header">
    <view class="header-title">更多服务</view>
  </view>

  <view class="content-wrap">
    <!-- 标书服务 -->
    <view class="section-card">
      <view class="card-hd">
        <view class="card-title">标书服务</view>
      </view>
      <view class="grid grid-3">
        <view class="grid-item" wx:for="{{templateItems}}" wx:key="type" bindtap="onItemTap" data-type="{{item.type}}">
          <view class="icon-box" style="background: {{item.color}}">
            <image class="icon-img" src="{{item.icon}}"></image>
          </view>
          <text class="icon-label">{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- 业务拓展 -->
    <view class="section-card">
      <view class="card-hd">
        <view class="card-title">业务拓展</view>
      </view>
      <view class="grid grid-4">
        <view class="grid-item" wx:for="{{businessItems}}" wx:key="type" bindtap="onItemTap" data-type="{{item.type}}">
          <view class="icon-box" style="background: {{item.color}}">
            <image class="icon-img" src="{{item.icon}}"></image>
            <view wx:if="{{item.badge}}" class="icon-badge">{{item.badge}}</view>
          </view>
          <text class="icon-label">{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- 数据服务 -->
    <view class="section-card">
      <view class="card-hd">
        <view class="card-title">数据服务</view>
      </view>
      <view class="grid grid-4">
        <view class="grid-item" wx:for="{{dataItems}}" wx:key="type" bindtap="onItemTap" data-type="{{item.type}}">
          <view class="icon-box" style="background: {{item.color}}">
            <image class="icon-img" src="{{item.icon}}"></image>
            <view wx:if="{{item.badge}}" class="icon-badge">{{item.badge}}</view>
          </view>
          <text class="icon-label">{{item.name}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
