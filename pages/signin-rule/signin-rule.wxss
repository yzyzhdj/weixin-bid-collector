.page {
  min-height: 100vh;
  background: #f1f5f9;
  padding-bottom: 40rpx;
}

/* 顶部蓝色背景 */
.page-header {
  background: linear-gradient(135deg, #1e88ff 0%, #42a5f5 100%);
  padding: 50rpx 40rpx 60rpx;
  color: #ffffff;
}

.page-header-title {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.page-header-sub {
  font-size: 26rpx;
  opacity: 0.85;
}

/* 卡片 */
.card {
  background: #ffffff;
  border-radius: 20rpx;
  margin: 30rpx 24rpx 0;
  padding: 30rpx 30rpx 36rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 24rpx;
}

.card-title-bar {
  width: 6rpx;
  height: 32rpx;
  background: #1e88ff;
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.card-body {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.7;
}

/* 规则条目 */
.rule-item {
  display: flex;
  margin-bottom: 18rpx;
}

.rule-item:last-child {
  margin-bottom: 0;
}

.rule-num {
  color: #1e88ff;
  font-weight: 600;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.rule-text {
  flex: 1;
  color: #475569;
  font-size: 28rpx;
}

/* 奖励表格 */
.reward-table {
  background: #f8fafc;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #e2e8f0;
}

.reward-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #e2e8f0;
  font-size: 28rpx;
}

.reward-row:last-child {
  border-bottom: none;
}

.reward-header {
  background: #e0f2fe;
  color: #1e293b;
  font-weight: 600;
}

.reward-col-left {
  flex: 1;
  text-align: left;
}

.reward-col-right {
  color: #f97316;
  font-weight: 600;
}

.reward-header .reward-col-right {
  color: #1e293b;
}

/* 底部安全距离 */
.safe-bottom {
  height: 40rpx;
}
