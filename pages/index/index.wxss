.container {
  padding: 0;
  background: #f1f5f9;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(180deg, #1e88ff 0%, #42a5f5 100%);
  padding: 0 32rpx 40rpx;
  position: relative;
  /* 兼容 iOS 11.2 以下 */
  padding-top: constant(safe-area-inset-top);
  /* iOS 11.2+ / 安卓全面屏 */
  padding-top: env(safe-area-inset-top);
}

.status-bar {
  width: 100%;
  /* 高度由 JS 动态设置，适配刘海屏 */
}

.header::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle at center, rgba(255, 255, 255, 0.15) 0%, transparent 60%);
  border-radius: 50%;
  pointer-events: none;
}

.header::after {
  content: '';
  position: absolute;
  top: 80rpx;
  left: 40rpx;
  width: 80rpx;
  height: 80rpx;
  background: radial-gradient(circle at center, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 60rpx;
  margin-bottom: 32rpx;
  position: relative;
  z-index: 2;
}

.region-picker {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 30rpx;
}

.region-text {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 500;
}

.region-arrow {
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-top: 10rpx solid #ffffff;
  margin-top: 4rpx;
}

/* 中间组：标题 + 铃铛，作为整体在 header-top 中水平居中 */
.header-center {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  flex: 1;
}

.header-title-text {
  font-size: 34rpx;
  color: #ffffff;
  font-weight: 600;
  letter-spacing: 2rpx;
  line-height: 1;
}

/* 右侧占位：与左侧地区选择器等宽，使中间组真正水平居中 */
.header-right-placeholder {
  min-width: 100rpx;
  height: 1rpx;
}

/* 消息通知铃铛：flex 子元素，与标题垂直居中对齐 */
.header-notice {
  position: relative;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3;
}

.header-notice-hover {
  opacity: 0.7;
}

.notice-bell {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 白色铃铛图标：用 SVG 数据 URI + CSS mask 实现（不受 emoji 默认颜色限制） */
.notice-bell-icon {
  width: 36rpx;
  height: 36rpx;
  background-color: #ffffff;
  -webkit-mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><path d='M12 22c1.1 0 2-.9 2-2h-4c0 1.1.9 2 2 2zm6-6v-5c0-3.07-1.63-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5S10.5 3.17 10.5 4v.68C7.64 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z'/></svg>") center center / contain no-repeat;
          mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><path d='M12 22c1.1 0 2-.9 2-2h-4c0 1.1.9 2 2 2zm6-6v-5c0-3.07-1.63-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5S10.5 3.17 10.5 4v.68C7.64 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z'/></svg>") center center / contain no-repeat;
}

.notice-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 6rpx;
  background: #ff3b30;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 600;
  line-height: 28rpx;
  text-align: center;
  border-radius: 14rpx;
  border: 2rpx solid rgba(30, 136, 255, 0.5);
  box-sizing: border-box;
}

.search-bar {
  background: #ffffff;
  border-radius: 50rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  gap: 16rpx;
  position: relative;
  z-index: 2;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  font-size: 32rpx;
  color: #94a3b8;
  line-height: 1;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #334155;
}

/* ====== Banner 轮播（纯 CSS 商用级设计） ====== */
.banner-swiper {
  width: 100%;
  height: 280rpx;
  margin-top: 28rpx;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
  z-index: 2;
  box-shadow: 0 8rpx 28rpx rgba(30, 136, 255, 0.2);
}

.banner-item {
  width: 100%;
  height: 280rpx;
  border-radius: 20rpx;
  position: relative;
  overflow: hidden;
}

/* ---- API Banner 图片模式 ---- */
.banner-api-item {
  background: #f5f5f5;
}
.banner-api-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}
.banner-api-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 50%;
  background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0) 100%);
  z-index: 2;
}
.banner-api-text {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 24rpx 32rpx;
  box-sizing: border-box;
  z-index: 3;
}
.banner-api-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 2rpx 6rpx rgba(0,0,0,0.4);
  line-height: 1.3;
}

/* ---- AI 主题：深蓝科技渐变 ---- */
.banner-theme-ai {
  background: linear-gradient(135deg, #0d3b7a 0%, #1565c0 25%, #1e88ff 55%, #42a5f5 100%);
}

/* ---- 签到主题：橙金渐变 ---- */
.banner-theme-signin {
  background: linear-gradient(135deg, #d84315 0%, #ef6c00 25%, #ff9800 55%, #ffb74d 100%);
}

/* 背景光晕 */
.banner-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(40rpx);
  opacity: 0.4;
}
.banner-glow-1 {
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, #64b5f6, transparent 70%);
  top: -100rpx;
  right: -60rpx;
}
.banner-glow-2 {
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, #e3f2fd, transparent 70%);
  bottom: -60rpx;
  left: 100rpx;
  opacity: 0.25;
}
.glow-gold {
  background: radial-gradient(circle, #ffd54f, transparent 70%) !important;
}
.glow-gold2 {
  background: radial-gradient(circle, #fff3e0, transparent 70%) !important;
}

/* 网点纹理装饰 */
.banner-dots-deco {
  position: absolute;
  width: 180rpx;
  height: 180rpx;
  background-image: radial-gradient(circle, rgba(255,255,255,0.25) 2rpx, transparent 2rpx);
  background-size: 16rpx 16rpx;
  z-index: 1;
}
.banner-dots-tr {
  top: -20rpx;
  right: -20rpx;
  border-radius: 0 0 0 180rpx;
}
.banner-dots-bl {
  bottom: -20rpx;
  left: -20rpx;
  border-radius: 0 180rpx 0 0;
  transform: rotate(180deg);
  opacity: 0.3;
}

/* 弧线装饰 */
.banner-arc {
  position: absolute;
  border: 3rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 50%;
  z-index: 1;
}
.banner-arc-1 {
  width: 500rpx;
  height: 500rpx;
  top: -280rpx;
  right: -200rpx;
  border-left-color: transparent;
  border-bottom-color: transparent;
}
.banner-arc-2 {
  width: 400rpx;
  height: 400rpx;
  bottom: -250rpx;
  left: -100rpx;
  border-right-color: transparent;
  border-top-color: transparent;
}

/* ========== AI 主题装饰 ========== */

/* 浮动文档卡片 */
.banner-float-card {
  position: absolute;
  background: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  z-index: 2;
}
.banner-card-doc {
  width: 100rpx;
  height: 120rpx;
  left: 40rpx;
  bottom: 36rpx;
  transform: rotate(-8deg);
  padding: 12rpx;
  box-sizing: border-box;
}
.banner-card-chart {
  width: 80rpx;
  height: 90rpx;
  left: 120rpx;
  top: 48rpx;
  transform: rotate(6deg);
  padding: 10rpx;
  box-sizing: border-box;
  background: linear-gradient(135deg, #ffffff, #f0f7ff);
}

/* 文档图标内容 */
.doc-icon {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.doc-lines {
  display: flex;
  flex-direction: column;
  gap: 5rpx;
}
.doc-line {
  height: 4rpx;
  background: #bbdefb;
  border-radius: 2rpx;
}
.doc-line-1 { width: 80%; }
.doc-line-2 { width: 60%; background: #90caf9; }
.doc-line-3 { width: 70%; }
.doc-line-4 { width: 40%; background: #90caf9; }
.chart-bars {
  display: flex;
  align-items: flex-end;
  gap: 5rpx;
  height: 28rpx;
}
.bar {
  width: 10rpx;
  border-radius: 2rpx 2rpx 0 0;
}
.bar-1 { height: 40%; background: #42a5f5; }
.bar-2 { height: 70%; background: #1e88ff; }
.bar-3 { height: 100%; background: #1565c0; }

/* 趋势线卡片 */
.trend-line {
  width: 100%;
  height: 50%;
  border-bottom: 3rpx solid #1e88ff;
  border-right: 3rpx solid #1e88ff;
  border-radius: 0 0 8rpx 0;
  position: relative;
  margin-top: 10rpx;
}
.trend-line::before {
  content: '';
  position: absolute;
  bottom: -3rpx;
  left: 0;
  width: 100%;
  height: 3rpx;
  background: linear-gradient(90deg, #42a5f5, #1e88ff, #1565c0);
  transform: skewY(-20deg);
  transform-origin: left bottom;
}
.trend-dot {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: #ff5722;
  border-radius: 50%;
  box-shadow: 0 0 6rpx rgba(255, 87, 34, 0.6);
}
.trend-dot-1 { left: 12rpx; bottom: 22rpx; }
.trend-dot-2 { left: 34rpx; bottom: 32rpx; }
.trend-dot-3 { left: 55rpx; bottom: 44rpx; }

/* AI 机器人 */
.banner-robot {
  position: absolute;
  right: 44rpx;
  bottom: 20rpx;
  width: 130rpx;
  height: 160rpx;
  z-index: 3;
  filter: drop-shadow(0 6rpx 12rpx rgba(0,0,0,0.2));
}
.robot-antenna {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 4rpx;
  height: 18rpx;
  background: linear-gradient(to top, #90caf9, #e3f2fd);
}
.antenna-ball {
  position: absolute;
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 14rpx;
  height: 14rpx;
  background: radial-gradient(circle at 30% 30%, #ffeb3b, #ff9800);
  border-radius: 50%;
  box-shadow: 0 0 10rpx rgba(255, 235, 59, 0.8);
  animation: robotGlow 2s ease-in-out infinite;
}
.robot-head {
  position: absolute;
  top: 18rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 88rpx;
  height: 70rpx;
  background: linear-gradient(180deg, #e3f2fd, #bbdefb);
  border-radius: 24rpx 24rpx 20rpx 20rpx;
  border: 3rpx solid #ffffff;
}
.robot-eye {
  position: absolute;
  top: 20rpx;
  width: 16rpx;
  height: 20rpx;
  background: #1565c0;
  border-radius: 8rpx;
}
.robot-eye-l { left: 18rpx; }
.robot-eye-r { right: 18rpx; }
.robot-eye::after {
  content: '';
  position: absolute;
  top: 3rpx;
  left: 3rpx;
  width: 6rpx;
  height: 6rpx;
  background: #ffffff;
  border-radius: 50%;
}
.robot-mouth {
  position: absolute;
  bottom: 12rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 28rpx;
  height: 8rpx;
  background: #1565c0;
  border-radius: 0 0 10rpx 10rpx;
}
.robot-body {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100rpx;
  height: 65rpx;
  background: linear-gradient(180deg, #bbdefb, #90caf9);
  border-radius: 16rpx 16rpx 20rpx 20rpx;
  border: 3rpx solid #ffffff;
}
.robot-light {
  position: absolute;
  top: 12rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 20rpx;
  height: 20rpx;
  background: radial-gradient(circle, #4caf50, #2e7d32);
  border-radius: 50%;
  border: 2rpx solid #ffffff;
  animation: robotBlink 1.5s ease-in-out infinite;
}
.robot-arm {
  position: absolute;
  top: 70rpx;
  width: 18rpx;
  height: 40rpx;
  background: linear-gradient(180deg, #bbdefb, #90caf9);
  border-radius: 10rpx;
  border: 2rpx solid #ffffff;
}
.robot-arm-l { left: -8rpx; transform: rotate(15deg); }
.robot-arm-r { right: -8rpx; transform: rotate(-25deg); animation: robotWave 2s ease-in-out infinite; transform-origin: top center; }
.robot-wave {
  position: absolute;
  top: -8rpx;
  left: -2rpx;
  width: 24rpx;
  height: 24rpx;
  background: #ffd54f;
  border-radius: 50%;
  border: 2rpx solid #ffffff;
}
.robot-wave::after {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 4rpx;
  height: 4rpx;
  background: #ffffff;
  border-radius: 50%;
  box-shadow: 10rpx 0 0 #ffffff, 5rpx 8rpx 0 #ffffff;
}

/* ========== 签到主题装饰 ========== */

/* 撒花纸屑 */
.banner-confetti {
  position: absolute;
  width: 10rpx;
  height: 14rpx;
  border-radius: 2rpx;
  z-index: 2;
  animation: confettiFloat 3s ease-in-out infinite;
}
.confetti-1 { background: #ffeb3b; top: 20rpx; right: 200rpx; transform: rotate(15deg); animation-delay: 0s; }
.confetti-2 { background: #ffffff; top: 50rpx; right: 280rpx; transform: rotate(-20deg); animation-delay: 0.5s; width: 8rpx; height: 8rpx; border-radius: 50%; }
.confetti-3 { background: #ff7043; top: 80rpx; right: 160rpx; transform: rotate(30deg); animation-delay: 1s; }
.confetti-4 { background: #fff9c4; top: 40rpx; right: 320rpx; transform: rotate(-10deg); animation-delay: 1.5s; width: 12rpx; height: 8rpx; border-radius: 50%; }
.confetti-5 { background: #ffecb3; top: 100rpx; right: 240rpx; transform: rotate(45deg); animation-delay: 2s; }

/* 日历卡片 */
.banner-calendar {
  position: absolute;
  left: 36rpx;
  bottom: 36rpx;
  width: 88rpx;
  height: 96rpx;
  z-index: 2;
  filter: drop-shadow(0 6rpx 12rpx rgba(0,0,0,0.15));
}
.cal-top {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 24rpx;
  background: linear-gradient(180deg, #e65100, #bf360c);
  border-radius: 10rpx 10rpx 0 0;
}
.cal-top::before, .cal-top::after {
  content: '';
  position: absolute;
  top: -8rpx;
  width: 8rpx;
  height: 14rpx;
  background: #ffccbc;
  border-radius: 4rpx;
}
.cal-top::before { left: 20rpx; }
.cal-top::after { right: 20rpx; }
.cal-body {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 78rpx;
  background: #ffffff;
  border-radius: 0 0 10rpx 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cal-check {
  width: 36rpx;
  height: 20rpx;
  border-left: 5rpx solid #4caf50;
  border-bottom: 5rpx solid #4caf50;
  transform: rotate(-45deg);
  margin-top: -10rpx;
}

/* 飘浮金币 */
.banner-coin {
  position: absolute;
  width: 36rpx;
  height: 36rpx;
  background: linear-gradient(135deg, #ffd54f 0%, #ffb300 50%, #ff8f00 100%);
  border-radius: 50%;
  border: 2rpx solid #ffe082;
  box-shadow: 0 4rpx 10rpx rgba(255, 143, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  animation: coinFloat 3s ease-in-out infinite;
}
.coin-inner {
  font-size: 20rpx;
  font-weight: 800;
  color: #bf360c;
}
.coin-1 { left: 140rpx; top: 32rpx; animation-delay: 0s; width: 28rpx; height: 28rpx; }
.coin-2 { left: 170rpx; top: 68rpx; animation-delay: 0.8s; }
.coin-3 { left: 100rpx; top: 90rpx; animation-delay: 1.6s; width: 24rpx; height: 24rpx; }

/* 礼盒 */
.banner-gift {
  position: absolute;
  right: 36rpx;
  bottom: 24rpx;
  width: 110rpx;
  height: 130rpx;
  z-index: 3;
  filter: drop-shadow(0 6rpx 12rpx rgba(0,0,0,0.2));
}
.gift-body {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 78rpx;
  background: linear-gradient(180deg, #ff7043, #e64a19);
  border-radius: 8rpx;
  border: 3rpx solid #ffffff;
  box-sizing: border-box;
}
.gift-lid {
  position: absolute;
  top: 24rpx;
  left: -6rpx;
  width: calc(100% + 12rpx);
  height: 28rpx;
  background: linear-gradient(180deg, #ff8a65, #ff7043);
  border-radius: 6rpx;
  border: 3rpx solid #ffffff;
  box-sizing: border-box;
}
.gift-ribbon-h {
  position: absolute;
  top: 36rpx;
  left: 0;
  width: 100%;
  height: 16rpx;
  background: linear-gradient(90deg, #ffd54f, #ffecb3, #ffd54f);
  z-index: 2;
}
.gift-ribbon-v {
  position: absolute;
  top: 24rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 16rpx;
  height: 84rpx;
  background: linear-gradient(180deg, #ffecb3, #ffd54f, #ffecb3);
  z-index: 3;
}
.gift-bow {
  position: absolute;
  top: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 4;
  width: 40rpx;
  height: 24rpx;
}
.bow-l, .bow-r {
  position: absolute;
  top: 0;
  width: 22rpx;
  height: 22rpx;
  background: radial-gradient(ellipse at 30% 40%, #ffecb3, #ffd54f);
  border-radius: 50% 50% 50% 50%;
  border: 2rpx solid #ffffff;
}
.bow-l { left: -4rpx; transform: rotate(-30deg); }
.bow-r { right: -4rpx; transform: rotate(30deg); }
.bow-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 14rpx;
  height: 14rpx;
  background: radial-gradient(circle, #ffb300, #ff8f00);
  border-radius: 50%;
  border: 2rpx solid #ffffff;
}

/* 星光装饰 */
.banner-star {
  position: absolute;
  background: #ffffff;
  clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
  z-index: 2;
  animation: starTwinkle 2s ease-in-out infinite;
}
.star-1 { width: 16rpx; height: 16rpx; top: 30rpx; right: 180rpx; animation-delay: 0s; }
.star-2 { width: 12rpx; height: 12rpx; top: 60rpx; right: 260rpx; animation-delay: 0.7s; opacity: 0.8; }
.star-3 { width: 10rpx; height: 10rpx; top: 100rpx; right: 200rpx; animation-delay: 1.4s; opacity: 0.6; }

/* ========== 文案 ========== */
.banner-text {
  position: absolute;
  left: 190rpx;
  top: 0;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  z-index: 5;
  max-width: 55%;
}
.banner-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1.25;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.25);
  letter-spacing: 0.5rpx;
}
.banner-sub {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.92);
  line-height: 1.5;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.15);
  margin-top: 4rpx;
}
.banner-tag {
  display: inline-block;
  align-self: flex-start;
  margin-bottom: 8rpx;
  padding: 3rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(6rpx);
  color: #ffffff;
  font-size: 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  font-weight: 600;
}
.tag-gold {
  background: rgba(255, 235, 59, 0.25);
  border-color: rgba(255, 235, 59, 0.5);
}

/* ========== 动画 ========== */
@keyframes robotGlow {
  0%, 100% { box-shadow: 0 0 10rpx rgba(255,235,59,0.8); }
  50% { box-shadow: 0 0 20rpx rgba(255,235,59,1), 0 0 30rpx rgba(255,152,0,0.5); }
}
@keyframes robotBlink {
  0%, 90%, 100% { opacity: 1; }
  95% { opacity: 0.3; }
}
@keyframes robotWave {
  0%, 100% { transform: rotate(-25deg); }
  50% { transform: rotate(-45deg) translateY(-8rpx); }
}
@keyframes confettiFloat {
  0%, 100% { transform: translateY(0) rotate(15deg); opacity: 0.9; }
  50% { transform: translateY(-12rpx) rotate(-15deg); opacity: 1; }
}
@keyframes coinFloat {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-10rpx) scale(1.08); }
}
@keyframes starTwinkle {
  0%, 100% { opacity: 0.6; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.2); }
}

.function-card {
  background: #ffffff;
  margin: 24rpx 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 32rpx 16rpx;
  position: relative;
  z-index: 3;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.function-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx 0;
}

.function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.function-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 10rpx rgba(30, 136, 255, 0.12);
}

.function-icon-img {
  width: 56rpx;
  height: 56rpx;
}

.function-name {
  font-size: 24rpx;
  color: #334155;
}

/* banner 用 button 重置 */
button.promo-banner {
  display: flex;
  align-items: center;
  margin: 0 24rpx;
  padding: 0;
  border: none;
  background: linear-gradient(135deg, #1e88ff 0%, #42a5f5 100%);
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  width: calc(100% - 48rpx);
}

button.promo-banner::after {
  border: none;
}

.promo-banner {
  background: linear-gradient(135deg, #1e88ff 0%, #42a5f5 100%);
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(30, 136, 255, 0.25);
}

.promo-decor {
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 160rpx;
  height: 160rpx;
  background: radial-gradient(circle, rgba(255, 215, 0, 0.3) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.promo-decor-2 {
  position: absolute;
  bottom: -30rpx;
  right: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.promo-text {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
  z-index: 1;
}

.promo-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.4;
}

.promo-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.3;
}

.promo-emoji {
  font-size: 64rpx;
  margin: 0 16rpx;
  z-index: 1;
}

.promo-btn {
  background: #ffffff;
  color: #1e88ff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  z-index: 1;
  white-space: nowrap;
}

.promo-image {
  font-size: 80rpx;
  margin-left: 16rpx;
  opacity: 0.9;
}

.info-tabs {
  background: #ffffff;
  display: flex;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.info-tab {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #64748b;
  padding: 28rpx 0;
  position: relative;
  font-weight: 500;
}

.info-tab.active {
  color: #1e88ff;
  font-weight: 600;
}

.info-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #1e88ff;
  border-radius: 2rpx;
}

.info-list {
  padding: 0 24rpx;
}

.info-item {
  background: #ffffff;
  padding: 28rpx 28rpx 24rpx;
  border-radius: 16rpx;
  margin-top: 20rpx;
}

.info-title {
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 500;
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.info-company {
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 20rpx;
}

.company-name {
  color: #1e88ff;
  font-weight: 500;
}

.info-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.info-tags {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.info-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  line-height: 1.4;
}

.info-time {
  font-size: 24rpx;
  color: #94a3b8;
}

.loading-state {
  padding: 100rpx 0;
  text-align: center;
  color: #94a3b8;
  font-size: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  position: relative;
  margin-bottom: 20rpx;
}

.spinner-ring {
  position: absolute;
  inset: 0;
  border: 4rpx solid #e2e8f0;
  border-top-color: #1e88ff;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}

.loading-text {
  font-size: 26rpx;
  color: #64748b;
}

@keyframes spin {
  0%   { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.load-more-tip {
  padding: 32rpx 0;
  text-align: center;
  color: #94a3b8;
  font-size: 24rpx;
}

.empty-state {
  padding: 200rpx 0;
  text-align: center;
  color: #94a3b8;
  font-size: 28rpx;
}

/* 省市选择器弹窗 */
.region-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.region-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 1001;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.region-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.region-panel-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.region-panel-close {
  font-size: 48rpx;
  color: #94a3b8;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 200;
  line-height: 1;
}

.region-panel-body {
  display: flex;
  flex: 1;
  overflow: hidden;
  height: 600rpx;
}

.region-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  border-right: 1rpx solid #f1f5f9;
}

.region-col:last-child {
  border-right: none;
}

.region-col-title {
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  color: #94a3b8;
  background: #f8fafc;
}

.region-list {
  flex: 1;
  overflow-y: auto;
}

.region-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #475569;
  border-bottom: 1rpx solid #f8fafc;
}

.region-item.active {
  background: #eff6ff;
  color: #1e88ff;
  font-weight: 600;
  position: relative;
}

.region-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 32rpx;
  background: #1e88ff;
  border-radius: 0 3rpx 3rpx 0;
}

.region-panel-footer {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f1f5f9;
  background: #ffffff;
}

