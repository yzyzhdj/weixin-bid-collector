.container {
  padding: 0;
  background: #f1f5f9;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(180deg, #1e88ff 0%, #42a5f5 100%);
  padding: 0 32rpx 40rpx;
  position: relative;
  /* 兼容 iOS 11.2 以下 */
  padding-top: constant(safe-area-inset-top);
  /* iOS 11.2+ / 安卓全面屏 */
  padding-top: env(safe-area-inset-top);
}

.status-bar {
  width: 100%;
  /* 高度由 JS 动态设置，适配刘海屏 */
}

.header::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle at center, rgba(255, 255, 255, 0.15) 0%, transparent 60%);
  border-radius: 50%;
  pointer-events: none;
}

.header::after {
  content: '';
  position: absolute;
  top: 80rpx;
  left: 40rpx;
  width: 80rpx;
  height: 80rpx;
  background: radial-gradient(circle at center, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 60rpx;
  margin-bottom: 32rpx;
  position: relative;
  z-index: 2;
}

.region-picker {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 30rpx;
}

.region-text {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 500;
}

.region-arrow {
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-top: 10rpx solid #ffffff;
  margin-top: 4rpx;
}

.header-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 34rpx;
  color: #ffffff;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.search-bar {
  background: #ffffff;
  border-radius: 50rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  gap: 16rpx;
  position: relative;
  z-index: 2;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  font-size: 32rpx;
  color: #94a3b8;
  line-height: 1;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #334155;
}

.hot-tags {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
  position: relative;
  z-index: 2;
}

.hot-tag {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 400;
  line-height: 1;
}

.function-card {
  background: #ffffff;
  margin: -24rpx 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 32rpx 16rpx;
  position: relative;
  z-index: 3;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.function-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx 0;
}

.function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.function-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 10rpx rgba(30, 136, 255, 0.12);
}

.function-icon-img {
  width: 56rpx;
  height: 56rpx;
}

.function-name {
  font-size: 24rpx;
  color: #334155;
}

.promo-banner {
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  overflow: hidden;
}

.promo-text {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex: 1;
}

.promo-subtitle {
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.4;
}

.promo-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e3a8a;
  line-height: 1.3;
}

.promo-image {
  font-size: 80rpx;
  margin-left: 16rpx;
  opacity: 0.9;
}

.info-tabs {
  background: #ffffff;
  display: flex;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.info-tab {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #64748b;
  padding: 28rpx 0;
  position: relative;
  font-weight: 500;
}

.info-tab.active {
  color: #1e88ff;
  font-weight: 600;
}

.info-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #1e88ff;
  border-radius: 2rpx;
}

.info-list {
  padding: 0 24rpx;
}

.info-item {
  background: #ffffff;
  padding: 28rpx 28rpx 24rpx;
  border-radius: 16rpx;
  margin-top: 20rpx;
}

.info-title {
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 500;
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.info-company {
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 20rpx;
}

.company-name {
  color: #1e88ff;
  font-weight: 500;
}

.info-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.info-tags {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.info-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  line-height: 1.4;
}

.info-time {
  font-size: 24rpx;
  color: #94a3b8;
}

.loading-state {
  padding: 100rpx 0;
  text-align: center;
  color: #94a3b8;
  font-size: 28rpx;
}

.empty-state {
  padding: 200rpx 0;
  text-align: center;
  color: #94a3b8;
  font-size: 28rpx;
}

/* 省市选择器弹窗 */
.region-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.region-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 1001;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.region-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.region-panel-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.region-panel-close {
  font-size: 48rpx;
  color: #94a3b8;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 200;
  line-height: 1;
}

.region-panel-body {
  display: flex;
  flex: 1;
  overflow: hidden;
  height: 600rpx;
}

.region-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  border-right: 1rpx solid #f1f5f9;
}

.region-col:last-child {
  border-right: none;
}

.region-col-title {
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  color: #94a3b8;
  background: #f8fafc;
}

.region-list {
  flex: 1;
  overflow-y: auto;
}

.region-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #475569;
  border-bottom: 1rpx solid #f8fafc;
}

.region-item.active {
  background: #eff6ff;
  color: #1e88ff;
  font-weight: 600;
  position: relative;
}

.region-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 32rpx;
  background: #1e88ff;
  border-radius: 0 3rpx 3rpx 0;
}

.region-panel-footer {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f1f5f9;
  background: #ffffff;
}

.region-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.region-btn-cancel {
  background: #f1f5f9;
  color: #475569;
  border: 1rpx solid #e2e8f0;
}

.region-btn-confirm {
  background: linear-gradient(135deg, #1e88ff 0%, #42a5f5 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(30, 136, 255, 0.3);
}

.region-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 筛选状态条 */
.filter-bar {
  background: #eff6ff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx;
  margin: 0 24rpx 0;
  margin-top: -24rpx;
  position: relative;
  z-index: 4;
  border-radius: 16rpx 16rpx 0 0;
  border: 1rpx solid #bfdbfe;
  border-bottom: none;
}

.filter-info {
  flex: 1;
  display: flex;
  align-items: center;
  font-size: 26rpx;
  min-width: 0;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.filter-label {
  color: #1e40af;
  font-weight: 500;
  flex-shrink: 0;
}

.filter-value {
  color: #1e88ff;
  font-weight: 600;
  flex-shrink: 0;
}

.filter-count {
  color: #64748b;
  font-size: 24rpx;
  margin-left: 4rpx;
  flex-shrink: 0;
}

.filter-clear {
  background: #ffffff;
  color: #1e88ff;
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid #1e88ff;
  margin-left: 16rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.filter-clear:active {
  background: #1e88ff;
  color: #ffffff;
}
