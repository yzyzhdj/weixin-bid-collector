/* 每日签到弹窗                                  */
/* ============================================ */

.signin-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.55);
  z-index: 1000;
}

.signin-popup {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 640rpx;
  z-index: 1001;
}

.signin-card {
  position: relative;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.25);
  padding-bottom: 36rpx;
}

.signin-close {
  position: absolute;
  top: 16rpx;
  right: 20rpx;
  width: 56rpx;
  height: 56rpx;
  line-height: 50rpx;
  text-align: center;
  font-size: 44rpx;
  color: #94a3b8;
  z-index: 5;
}

.signin-header {
  position: relative;
  height: 200rpx;
  background: linear-gradient(135deg, #dbeafe 0%, #ffffff 70%);
  overflow: hidden;
}

.signin-cloud {
  position: absolute;
  background: #ffffff;
  border-radius: 50%;
  opacity: 0.85;
}

.signin-cloud-1 {
  width: 120rpx;
  height: 60rpx;
  top: 40rpx;
  left: 60rpx;
  box-shadow: 50rpx 10rpx 0 -10rpx #ffffff;
}

.signin-cloud-2 {
  width: 80rpx;
  height: 40rpx;
  top: 80rpx;
  right: 80rpx;
  box-shadow: 40rpx -10rpx 0 -10rpx #ffffff;
}

.signin-cloud-3 {
  width: 60rpx;
  height: 30rpx;
  top: 30rpx;
  right: 200rpx;
  box-shadow: 30rpx 5rpx 0 -5rpx #ffffff;
}

.signin-calendar {
  position: absolute;
  left: 50%;
  top: 40rpx;
  transform: translateX(-50%);
  width: 110rpx;
  height: 130rpx;
  background: #ffffff;
  border-radius: 14rpx;
  box-shadow: 0 6rpx 20rpx rgba(30, 136, 255, 0.15);
  overflow: hidden;
}

.signin-cal-top {
  height: 24rpx;
  background: #1e88ff;
}

.signin-cal-body {
  position: relative;
  height: 106rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.signin-cal-ring {
  width: 48rpx;
  height: 48rpx;
  border: 6rpx solid #1e88ff;
  border-radius: 50%;
  position: relative;
}

.signin-cal-ring::before {
  content: '';
  position: absolute;
  top: 8rpx;
  left: 14rpx;
  width: 6rpx;
  height: 14rpx;
  background: #1e88ff;
  transform: rotate(45deg);
}

.signin-cal-stick {
  position: absolute;
  bottom: 18rpx;
  width: 4rpx;
  height: 26rpx;
  background: #1e88ff;
  transform: translateX(8rpx) rotate(45deg);
  transform-origin: bottom;
}

.signin-title {
  text-align: center;
  font-size: 38rpx;
  font-weight: 700;
  color: #1e293b;
  margin-top: 30rpx;
}

.signin-subtitle {
  text-align: center;
  font-size: 26rpx;
  color: #64748b;
  margin-top: 8rpx;
}

.signin-days {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-top: 6rpx;
}

.signin-days-num {
  font-size: 56rpx;
  font-weight: 700;
  color: #f97316;
  line-height: 1.1;
}

.signin-days-unit {
  font-size: 26rpx;
  color: #f97316;
  margin-left: 8rpx;
  font-weight: 500;
}

.signin-week {
  display: flex;
  justify-content: space-between;
  margin: 28rpx 30rpx 0;
  padding: 24rpx 16rpx;
  background: #f8fafc;
  border-radius: 16rpx;
}

.signin-day {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.signin-day-circle {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #ffffff;
  border: 2rpx solid #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
  position: relative;
}

.signin-day.is-today .signin-day-circle {
  background: #eff6ff;
  border-color: #1e88ff;
}

.signin-day.is-signed .signin-day-circle {
  background: #1e88ff;
  border-color: #1e88ff;
}

.signin-day-check {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
}

.signin-day-empty {
  font-size: 28rpx;
  line-height: 1;
}

.signin-day-tag {
  position: absolute;
  top: -14rpx;
  background: #1e88ff;
  color: #ffffff;
  font-size: 18rpx;
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
  white-space: nowrap;
  z-index: 2;
}

.signin-day-label {
  font-size: 22rpx;
  color: #475569;
  margin-bottom: 2rpx;
}

.signin-day-points {
  font-size: 22rpx;
  color: #f97316;
  font-weight: 600;
}

.signin-btn {
  margin: 30rpx 30rpx 0;
  height: 88rpx;
  background: linear-gradient(135deg, #1e88ff 0%, #42a5f5 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 2rpx;
  box-shadow: 0 8rpx 20rpx rgba(30, 136, 255, 0.35);
}

.signin-btn.is-done {
  background: #e2e8f0;
  color: #94a3b8;
  box-shadow: none;
}

.signin-tip {
  text-align: center;
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 20rpx;
}

.signin-rule-link {
  text-align: center;
  font-size: 24rpx;
  color: #64748b;
  margin-top: 16rpx;
  padding: 6rpx 0;
}


.region-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.region-btn-cancel {
  background: #f1f5f9;
  color: #475569;
  border: 1rpx solid #e2e8f0;
}

.region-btn-confirm {
  background: linear-gradient(135deg, #1e88ff 0%, #42a5f5 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(30, 136, 255, 0.3);
}

.region-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 筛选状态条 */
.filter-bar {
  background: #eff6ff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx;
  margin: 0 24rpx 0;
  margin-top: -24rpx;
  position: relative;
  z-index: 4;
  border-radius: 16rpx 16rpx 0 0;
  border: 1rpx solid #bfdbfe;
  border-bottom: none;
}

.filter-info {
  flex: 1;
  display: flex;
  align-items: center;
  font-size: 26rpx;
  min-width: 0;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.filter-label {
  color: #1e40af;
  font-weight: 500;
  flex-shrink: 0;
}

.filter-value {
  color: #1e88ff;
  font-weight: 600;
  flex-shrink: 0;
}

.filter-count {
  color: #64748b;
  font-size: 24rpx;
  margin-left: 4rpx;
  flex-shrink: 0;
}

.filter-clear {
  background: #ffffff;
  color: #1e88ff;
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid #1e88ff;
  margin-left: 16rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.filter-clear:active {
  background: #1e88ff;
  color: #ffffff;
}
