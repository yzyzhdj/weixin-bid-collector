.container {
  padding-bottom: 20rpx;
}

.header {
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  padding: 40rpx 32rpx 32rpx;
}

.tabs {
  display: flex;
  justify-content: center;
  gap: 60rpx;
}

.tab {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.7);
  padding: 8rpx 0;
  position: relative;
}

.tab.active {
  color: #ffffff;
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #ffffff;
  border-radius: 3rpx;
}

.search-box {
  margin: -20rpx 32rpx 0;
  position: relative;
  z-index: 10;
}

.search-input-wrapper {
  background: #ffffff;
  border-radius: 60rpx;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #334155;
}

.hot-tags {
  display: flex;
  align-items: center;
  padding: 32rpx;
  gap: 16rpx;
}

.tags-scroll {
  flex: 1;
  white-space: nowrap;
}

.tags-list {
  display: flex;
  gap: 16rpx;
}

.tag {
  background: #dbeafe;
  color: #1e40af;
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  flex-shrink: 0;
}

.refresh-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.6;
}

.function-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  padding: 0 32rpx 24rpx;
  gap: 32rpx 16rpx;
}

.function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.function-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-img {
  width: 48rpx;
  height: 48rpx;
}

.function-name {
  font-size: 24rpx;
  color: #334155;
}

.exhibition-banner {
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
  margin: 0 32rpx 32rpx;
  padding: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.banner-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.exhibition-icon {
  width: 56rpx;
  height: 56rpx;
}

.banner-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.banner-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.banner-subtitle {
  font-size: 24rpx;
  color: #64748b;
}

.banner-btn {
  background: #ffffff;
  color: #2563eb;
  padding: 16rpx 24rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.stats-section {
  background: #ffffff;
  margin: 0 32rpx;
  padding: 32rpx;
  border-radius: 16rpx;
}

.stats-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.stats-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

.chart-icon {
  width: 36rpx;
  height: 36rpx;
}

.stats-date {
  font-size: 24rpx;
  color: #94a3b8;
}

.more-link {
  font-size: 26rpx;
  color: #64748b;
}

.stats-tabs {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.stat-tab {
  font-size: 28rpx;
  color: #64748b;
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  background: #f1f5f9;
}

.stat-tab.active {
  background: #2563eb;
  color: #ffffff;
}

.stats-data {
  display: flex;
  gap: 48rpx;
}

.data-row {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.data-label {
  font-size: 26rpx;
  color: #64748b;
}

.data-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e293b;
}
