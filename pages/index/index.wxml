<view class="container">
  <!-- 顶部蓝色区域 -->
  <view class="header">
    <view class="header-top">
      <view class="region-picker" bindtap="showRegionPicker">
        <text class="region-text">{{region}}<text wx:if="{{city}}"> · {{city}}</text></text>
        <view class="region-arrow"></view>
      </view>
      <view class="header-title">阳光标讯</view>
    </view>

    <view class="search-bar">
      <view class="search-icon">🔍</view>
      <input class="search-input" placeholder="请输入您想要查看的关键词" value="{{searchText}}" bindinput="onInput" bindconfirm="onSearch" confirm-type="search"></input>
    </view>

    <view class="hot-tags">
      <view class="hot-tag" wx:for="{{hotTags}}" wx:key="index" bindtap="onTagClick" data-keyword="{{item}}">{{item}}</view>
    </view>
  </view>

  <!-- 筛选状态条 -->
  <view class="filter-bar" wx:if="{{selectedProvince || selectedCity}}">
    <view class="filter-info">
      <text class="filter-label">已筛选：</text>
      <text class="filter-value" wx:if="{{selectedProvince}}">{{selectedProvince}}</text>
      <text class="filter-value" wx:if="{{selectedCity}}"> · {{selectedCity}}</text>
      <text class="filter-count">（{{infoList.length}} 条结果）</text>
    </view>
    <view class="filter-clear" bindtap="onClearFilter">清除</view>
  </view>

  <!-- 省市选择器弹窗 -->
  <view class="region-mask" wx:if="{{regionPickerShow}}" bindtap="hideRegionPicker"></view>
  <view class="region-panel" wx:if="{{regionPickerShow}}">
    <view class="region-panel-header">
      <text class="region-panel-title">选择地区</text>
      <view class="region-panel-close" bindtap="hideRegionPicker">×</view>
    </view>
    <view class="region-panel-body">
      <view class="region-col">
        <view class="region-col-title">省份</view>
        <scroll-view class="region-list" scroll-y>
          <view class="region-item {{selectedProvince === '' ? 'active' : ''}}" bindtap="selectProvince" data-province="">
            <text>全国</text>
          </view>
          <view class="region-item {{selectedProvince === item ? 'active' : ''}}" wx:for="{{provinces}}" wx:key="*this" bindtap="selectProvince" data-province="{{item}}">
            <text>{{item}}</text>
          </view>
        </scroll-view>
      </view>
      <view class="region-col" wx:if="{{cities.length > 0}}">
        <view class="region-col-title">{{selectedProvince || '城市'}}</view>
        <scroll-view class="region-list" scroll-y>
          <view class="region-item {{selectedCity === '' ? 'active' : ''}}" bindtap="selectCity" data-city="">
            <text>全部</text>
          </view>
          <view class="region-item {{selectedCity === item ? 'active' : ''}}" wx:for="{{cities}}" wx:key="*this" bindtap="selectCity" data-city="{{item}}">
            <text>{{item}}</text>
          </view>
        </scroll-view>
      </view>
    </view>
    <view class="region-panel-footer">
      <view class="region-btn region-btn-cancel" bindtap="onResetFilter">重置</view>
      <view class="region-btn region-btn-confirm" bindtap="onConfirmRegion">确认筛选</view>
    </view>
  </view>

  <!-- 功能宫格 -->
  <view class="function-card">
    <view class="function-grid">
      <view class="function-item" wx:for="{{functionList}}" wx:key="index" bindtap="onFunctionClick" data-type="{{item.type}}">
        <view class="function-icon" style="background: {{item.color}}">
          <image class="function-icon-img" src="{{item.icon}}"></image>
        </view>
        <text class="function-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 推广 banner -->
  <view class="promo-banner" bindtap="onPromoTap">
    <view class="promo-text">
      <view class="promo-subtitle">资质业绩、从业人员、荣誉奖项、信用评价</view>
      <view class="promo-title">全国建筑企业轻松查询</view>
    </view>
    <view class="promo-image">📊</view>
  </view>

  <!-- 标签切换 -->
  <view class="info-tabs">
    <view class="info-tab {{currentInfoTab === index ? 'active' : ''}}" wx:for="{{infoTabs}}" wx:key="index" bindtap="switchInfoTab" data-index="{{index}}">
      {{item}}
    </view>
  </view>

  <!-- 资讯列表 -->
  <view class="info-list" wx:if="{{!loading && infoList.length > 0}}">
    <view class="info-item" wx:for="{{infoList}}" wx:key="id" bindtap="onItemTap" data-id="{{item.id}}">
      <view class="info-title">{{item.title}}</view>
      <view class="info-company">招采单位：<text class="company-name">{{item.company}}</text></view>
      <view class="info-bottom">
        <view class="info-tags">
          <view class="info-tag" style="background: #e0f2fe; color: #0369a1;">{{item.region}}<text wx:if="{{item.region2}}"> · {{item.region2}}</text></view>
          <view class="info-tag" wx:if="{{item.tag}}" style="background: {{item.tagBg}}; color: {{item.tagColor}};">{{item.tag}}</view>
        </view>
        <text class="info-time">{{item.time}}</text>
      </view>
    </view>
  </view>
  <view class="empty-state" wx:if="{{!loading && infoList.length === 0}}">
    <text>暂无数据</text>
  </view>
  <view class="loading-state" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
