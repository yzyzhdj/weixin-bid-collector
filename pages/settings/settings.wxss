.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}

.header {
  position: relative;
  background: #ffffff;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #e5e7eb;
}

.back-btn {
  position: absolute;
  left: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 40rpx;
  height: 40rpx;
}

.header-title {
  text-align: center;
  color: #1f2937;
  font-size: 34rpx;
  font-weight: 600;
  padding: 24rpx 0 12rpx;
}

.menu-list {
  background: #ffffff;
  margin: 24rpx 0;
  border-radius: 0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  gap: 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #1f2937;
}

.menu-arrow-img {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  opacity: 0.4;
}
