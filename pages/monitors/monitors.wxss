.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}
.header {
  background: linear-gradient(135deg, #1e88ff 0%, #1565c0 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}
.back-btn {
  font-size: 60rpx;
  width: 60rpx;
  line-height: 60rpx;
  text-align: center;
  color: #ffffff;
}
.header-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
}
.add-btn {
  font-size: 26rpx;
  color: #ffffff;
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
}
.list {
  padding: 24rpx;
}
.list-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.item-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.item-switch {
  transform: scale(0.8);
  margin-left: 12rpx;
}
.item-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.tag {
  font-size: 22rpx;
  color: #475569;
  background: #f1f5f9;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
}
.item-foot {
  border-top: 1rpx solid #e2e8f0;
  padding-top: 16rpx;
  text-align: right;
}
.meta-link {
  font-size: 24rpx;
  color: #1e88ff;
}
.empty {
  text-align: center;
  padding: 200rpx 32rpx;
}
.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}
.empty-text {
  font-size: 30rpx;
  color: #475569;
  margin-bottom: 12rpx;
}
.empty-hint {
  font-size: 24rpx;
  color: #94a3b8;
}
.loading {
  text-align: center;
  padding: 32rpx;
  color: #94a3b8;
  font-size: 24rpx;
}
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}
.modal-panel {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}
.modal-title {
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  padding: 0 0 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
}
.form {
  flex: 1;
  overflow-y: auto;
  padding: 0 24rpx;
}
.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}
.form-label {
  width: 200rpx;
  font-size: 28rpx;
  color: #475569;
}
.form-label.required::before {
  content: '*';
  color: #ef4444;
  margin-right: 4rpx;
}
.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #1e293b;
}
.form-picker {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #1e293b;
}
.form-picker .placeholder {
  color: #94a3b8;
}
.form-picker .arrow {
  color: #94a3b8;
  font-size: 32rpx;
}
.form-switch {
  transform: scale(0.9);
}
.modal-actions {
  display: flex;
  border-top: 1rpx solid #f1f5f9;
}
.action-cancel,
.action-save {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
}
.action-cancel {
  color: #64748b;
  border-right: 1rpx solid #f1f5f9;
}
.action-save {
  color: #1e88ff;
  font-weight: 600;
}
.modal-list {
  padding: 16rpx 0;
}
.modal-item {
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  color: #334155;
  border-bottom: 1rpx solid #f8fafc;
}
.modal-cancel {
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
  color: #64748b;
  border-top: 1rpx solid #f1f1f5;
}
