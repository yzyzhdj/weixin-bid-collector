.container {
  background: #f1f5f9;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ========== 顶部蓝色渐变区域 ========== */
.header {
  background: linear-gradient(180deg, #1e88ff 0%, #42a5f5 100%);
  padding: 0 32rpx 200rpx;
  position: relative;
  overflow: hidden;
  /* 刘海屏适配 */
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
}

/* 装饰圆 - 右上 */
.header::before {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 360rpx;
  height: 360rpx;
  background: radial-gradient(circle at center, rgba(255, 255, 255, 0.15) 0%, transparent 65%);
  border-radius: 50%;
  pointer-events: none;
}

/* 装饰圆 - 左下 */
.header::after {
  content: '';
  position: absolute;
  top: 180rpx;
  left: -100rpx;
  width: 320rpx;
  height: 320rpx;
  background: radial-gradient(circle at center, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60rpx;
  margin-bottom: 40rpx;
  position: relative;
  z-index: 2;
}

.header-title {
  font-size: 34rpx;
  color: #ffffff;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* 设置按钮 */
.settings-btn {
  position: absolute;
  top: 0;
  right: 32rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.settings-icon {
  width: 36rpx;
  height: 36rpx;
}

/* ========== 用户信息 ========== */
.user-card {
  position: relative;
  z-index: 2;
  padding: 0 8rpx;
}

.user-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  flex-shrink: 0;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-width: 0;
}

.user-name {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.user-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ========== VIP 卡片 ========== */
.vip-card {
  margin: -160rpx 24rpx 0;
  background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  z-index: 3;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  overflow: hidden;
}

.vip-card::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 240rpx;
  height: 100%;
  background: radial-gradient(circle at right, rgba(251, 191, 36, 0.18) 0%, transparent 60%);
  pointer-events: none;
}

.vip-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.vip-title {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.vip-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #fbbf24;
  font-style: italic;
  letter-spacing: 1rpx;
}

.vip-text-main {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

.vip-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.vip-btn {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  color: #ffffff;
  font-size: 24rpx;
  padding: 16rpx 28rpx;
  border-radius: 30rpx;
  font-weight: 500;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(245, 158, 11, 0.3);
}

/* ========== 快捷功能 ========== */
.quick-actions {
  display: flex;
  background: #ffffff;
  margin: 24rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 36rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.action-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 与首页功能宫格保持一致 */
.action-icon-wrap.blue {
  background: linear-gradient(135deg, #1e88ff 0%, #42a5f5 100%);
}

.action-icon-wrap.orange {
  background: linear-gradient(135deg, #f97316 0%, #fb923c 100%);
}

.action-icon-wrap.green {
  background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
}

.action-icon-img {
  width: 48rpx;
  height: 48rpx;
}

.action-text {
  font-size: 26rpx;
  color: #334155;
  font-weight: 500;
}

/* ========== 菜单列表 ========== */
.menu-list {
  background: #ffffff;
  margin: 24rpx 24rpx 0;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  gap: 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon-wrap {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: #1e88ff;
}

.menu-icon-img {
  width: 40rpx;
  height: 40rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #1e293b;
}

.menu-value {
  font-size: 26rpx;
  color: #94a3b8;
  flex-shrink: 0;
}

.menu-arrow-img {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  margin-left: 8rpx;
  opacity: 0.5;
}
