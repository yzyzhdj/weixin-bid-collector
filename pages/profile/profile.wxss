.container {
  background: #f1f5f9;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ========== 顶部蓝色渐变区域 ========== */
.header {
  background: linear-gradient(180deg, #1e88ff 0%, #42a5f5 100%);
  padding: 0 32rpx 100rpx;
  position: relative;
  overflow: hidden;
  /* 刘海屏适配 */
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
}

/* 装饰圆 - 右上 */
.header::before {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 360rpx;
  height: 360rpx;
  background: radial-gradient(circle at center, rgba(255, 255, 255, 0.15) 0%, transparent 65%);
  border-radius: 50%;
  pointer-events: none;
}

/* 装饰圆 - 左下 */
.header::after {
  content: '';
  position: absolute;
  top: 180rpx;
  left: -100rpx;
  width: 320rpx;
  height: 320rpx;
  background: radial-gradient(circle at center, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60rpx;
  margin-bottom: 40rpx;
  position: relative;
  z-index: 2;
}

.header-title {
  font-size: 34rpx;
  color: #ffffff;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* 设置按钮 */
.settings-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.settings-icon {
  width: 44rpx;
  height: 44rpx;
}

/* ========== 用户信息 ========== */
.user-card {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 0 8rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1e88ff 0%, #4facfe 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(30, 136, 255, 0.25);
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  flex-shrink: 0;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
  flex: 1;
}

.user-right {
  flex-shrink: 0;
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.msg-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.msg-icon {
  width: 36rpx;
  height: 36rpx;
}

.msg-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: #ef4444;
  color: #fff;
  font-size: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.user-name {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: 600;
  letter-spacing: 1rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.user-level {
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.25);
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  font-weight: 400;
  color: #ffffff;
}

.user-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ========== 积分卡片（白底，与蓝色顶部形成对比） ========== */
.points-card {
  margin: -80rpx 24rpx 0;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  z-index: 3;
  box-shadow: 0 8rpx 32rpx rgba(30, 136, 255, 0.15);
  overflow: hidden;
  border-top: 6rpx solid #1e88ff;
}

.points-card::before {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 280rpx;
  height: 280rpx;
  background: radial-gradient(circle at center, rgba(30, 136, 255, 0.06) 0%, transparent 65%);
  border-radius: 50%;
  pointer-events: none;
}

.points-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  position: relative;
  z-index: 1;
}

.points-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.points-label {
  font-size: 26rpx;
  color: #64748b;
}

.points-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #1e88ff;
  line-height: 1;
}

.points-tip {
  font-size: 22rpx;
  color: #94a3b8;
}

.points-btn {
  background: linear-gradient(135deg, #1e88ff 0%, #4facfe 100%);
  color: #ffffff;
  font-size: 26rpx;
  padding: 18rpx 36rpx;
  border-radius: 32rpx;
  font-weight: 600;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(30, 136, 255, 0.3);
  position: relative;
  z-index: 1;
}

/* ========== 快捷功能 ========== */
.quick-actions {
  display: flex;
  background: #ffffff;
  margin: 24rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 36rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.action-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 与首页功能宫格保持一致 */
.action-icon-wrap.blue {
  background: linear-gradient(135deg, #1e88ff 0%, #42a5f5 100%);
}

.action-icon-wrap.orange {
  background: linear-gradient(135deg, #f97316 0%, #fb923c 100%);
}

.action-icon-wrap.green {
  background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
}

.action-icon-img {
  width: 48rpx;
  height: 48rpx;
}

.action-text {
  font-size: 26rpx;
  color: #334155;
  font-weight: 500;
}

/* ========== 菜单列表 ========== */
.menu-list {
  background: #ffffff;
  margin: 24rpx 24rpx 0;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  gap: 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon-wrap {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: #1e88ff;
}

.menu-icon-img {
  width: 40rpx;
  height: 40rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #1e293b;
}

.menu-value {
  font-size: 26rpx;
  color: #94a3b8;
  flex-shrink: 0;
}

.menu-extra {
  font-size: 26rpx;
  color: #94a3b8;
  margin-right: 12rpx;
}

.menu-arrow-img {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  margin-left: 8rpx;
  opacity: 0.5;
}
