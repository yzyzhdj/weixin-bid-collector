.container {
  padding: 0;
  background: #f1f5f9;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(180deg, #1e88ff 0%, #42a5f5 100%);
  padding: 0 32rpx 240rpx;
  position: relative;
  overflow: hidden;
  /* 兼容 iOS 11.2 以下 */
  padding-top: constant(safe-area-inset-top);
  /* iOS 11.2+ / 安卓全面屏 */
  padding-top: env(safe-area-inset-top);
}

.header::before {
  content: '';
  position: absolute;
  top: -50rpx;
  right: -50rpx;
  width: 320rpx;
  height: 320rpx;
  background: radial-gradient(circle at center, rgba(255, 255, 255, 0.12) 0%, transparent 60%);
  border-radius: 50%;
  pointer-events: none;
}

.header::after {
  content: '';
  position: absolute;
  top: 200rpx;
  left: -80rpx;
  width: 280rpx;
  height: 280rpx;
  background: radial-gradient(circle at center, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60rpx;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 2;
}

.header-title {
  font-size: 34rpx;
  color: #ffffff;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.settings-btn {
  position: absolute;
  top: 0;
  right: 32rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.settings-icon {
  width: 36rpx;
  height: 36rpx;
}
.user-card {
  position: relative;
  z-index: 2;
}

.user-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  flex-shrink: 0;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-width: 0;
}

.user-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.user-phone {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: 600;
}

.user-badge {
  font-size: 22rpx;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.25);
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  font-weight: 500;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  flex-shrink: 0;
}

.user-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.vip-card {
  margin: -180rpx 24rpx 0;
  background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  z-index: 3;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  overflow: hidden;
}

.vip-card::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 200rpx;
  height: 100%;
  background: radial-gradient(circle at right, rgba(251, 191, 36, 0.15) 0%, transparent 60%);
  pointer-events: none;
}

.vip-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.vip-title {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.vip-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #fbbf24;
  font-style: italic;
  letter-spacing: 1rpx;
}

.vip-text-main {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

.vip-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.vip-btn {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  color: #ffffff;
  font-size: 24rpx;
  padding: 16rpx 24rpx;
  border-radius: 30rpx;
  font-weight: 500;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(245, 158, 11, 0.3);
}

.notice-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 32rpx;
  font-size: 24rpx;
  color: #64748b;
  margin: 32rpx 24rpx 0;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.notice-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.notice-time {
  color: #94a3b8;
  font-size: 24rpx;
  flex-shrink: 0;
}

.notice-text {
  flex: 1;
  color: #475569;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.quick-actions {
  display: flex;
  background: #ffffff;
  margin: 24rpx 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 36rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.action-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 与首页功能宫格保持一致：渐变背景 + 白色图标 */
.action-icon-wrap.blue {
  background: linear-gradient(135deg, #1e88ff 0%, #42a5f5 100%);
}

.action-icon-wrap.orange {
  background: linear-gradient(135deg, #f97316 0%, #fb923c 100%);
}

.action-icon-wrap.green {
  background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
}

.action-icon-img {
  width: 56rpx;
  height: 56rpx;
  /* 图标已是纯白色填充，在渐变背景上自然显示 */
}

.action-text {
  font-size: 26rpx;
  color: #334155;
  font-weight: 500;
}

/* 用户卡片右侧（编辑资料/登录）*/
.user-right-arrow {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #ffffff;
  font-size: 24rpx;
  opacity: 0.85;
}

.user-action-text { color: #ffffff; }
.user-arrow { font-size: 32rpx; line-height: 1; }

/* VIP 用户徽章 */
.user-badge.vip {
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  color: #ffffff;
}

/* 数据统计卡 */
.stats-card {
  display: flex;
  align-items: center;
  background: #ffffff;
  margin: 24rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 32rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 600;
  color: #1e293b;
  line-height: 1.2;
}

.stat-label {
  font-size: 24rpx;
  color: #94a3b8;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: #e2e8f0;
}

.menu-list {
  background: #ffffff;
  margin: 0 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  gap: 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon-wrap {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon-img {
  width: 40rpx;
  height: 40rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #1e293b;
}

.menu-value {
  font-size: 26rpx;
  color: #94a3b8;
  flex-shrink: 0;
}

.menu-arrow-img {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  margin-left: 8rpx;
}
