<view class="container">
  <!-- 顶部蓝色渐变区域 -->
  <view class="header">
    <!-- 标题栏 -->
    <view class="header-top">
      <view class="header-title">个人中心</view>
    </view>

    <!-- 设置图标 -->
    <view class="settings-btn" bindtap="onSettingsTap" style="top: {{settingsBtnTop}}px;">
      <image class="settings-icon" src="/images/icon-settings.svg"></image>
    </view>

    <!-- 用户信息 -->
    <view class="user-card">
      <view class="user-left">
        <view class="avatar">
          <image class="avatar-img" src="/images/avatar-default.svg"></image>
        </view>
        <view class="user-info">
          <view class="user-name" bindtap="onLoginTap">点击登录</view>
          <view class="user-tip">登录获取更多服务</view>
        </view>
      </view>
    </view>
  </view>

  <!-- VIP 卡片（与头部蓝色区域衔接） -->
  <view class="vip-card" bindtap="onOpenVip">
    <view class="vip-left">
      <view class="vip-title">
        <text class="vip-text">VIP</text>
        <text class="vip-text-main">开通会员</text>
      </view>
      <view class="vip-subtitle">开通立享多重特权，可享超大折扣</view>
    </view>
    <view class="vip-btn">去开通 ></view>
  </view>

  <!-- 快捷功能 -->
  <view class="quick-actions">
    <view class="action-item" bindtap="onActionTap" data-type="subscription">
      <view class="action-icon-wrap blue">
        <image class="action-icon-img" src="/images/icon-qa-subscription.svg"></image>
      </view>
      <text class="action-text">我的订阅</text>
    </view>
    <view class="action-item" bindtap="onActionTap" data-type="favorite">
      <view class="action-icon-wrap orange">
        <image class="action-icon-img" src="/images/icon-qa-favorite.svg"></image>
      </view>
      <text class="action-text">我的收藏</text>
    </view>
    <view class="action-item" bindtap="onActionTap" data-type="custom">
      <view class="action-icon-wrap green">
        <image class="action-icon-img" src="/images/icon-qa-custom.svg"></image>
      </view>
      <text class="action-text">信息定制</text>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="onMenuTap" data-type="buy">
      <view class="menu-icon-wrap blue-icon">
        <image class="menu-icon-img" src="/images/icon-buy.svg"></image>
      </view>
      <text class="menu-text">购买会员</text>
      <image class="menu-arrow-img" src="/images/icon-arrow-right.svg"></image>
    </view>
    <view class="menu-item" bindtap="onMenuTap" data-type="orders">
      <view class="menu-icon-wrap blue-icon">
        <image class="menu-icon-img" src="/images/icon-history.svg"></image>
      </view>
      <text class="menu-text">购买记录</text>
      <image class="menu-arrow-img" src="/images/icon-arrow-right.svg"></image>
    </view>
    <view class="menu-item" bindtap="onMenuTap" data-type="service">
      <view class="menu-icon-wrap blue-icon">
        <image class="menu-icon-img" src="/images/icon-service.svg"></image>
      </view>
      <text class="menu-text">客服热线</text>
      <image class="menu-arrow-img" src="/images/icon-arrow-right.svg"></image>
    </view>
    <view class="menu-item" bindtap="onMenuTap" data-type="cooperation">
      <view class="menu-icon-wrap blue-icon">
        <image class="menu-icon-img" src="/images/icon-cooperation.svg"></image>
      </view>
      <text class="menu-text">渠道合作</text>
      <image class="menu-arrow-img" src="/images/icon-arrow-right.svg"></image>
    </view>
    <view class="menu-item" bindtap="onMenuTap" data-type="feedback">
      <view class="menu-icon-wrap blue-icon">
        <image class="menu-icon-img" src="/images/icon-feedback.svg"></image>
      </view>
      <text class="menu-text">意见反馈</text>
      <image class="menu-arrow-img" src="/images/icon-arrow-right.svg"></image>
    </view>
  </view>

  <!-- API 调试面板 (开发用) -->
  <view class="debug-panel" bindtap="toggleDebug">
    <view class="debug-title">🔧 API 调试</view>
    <view wx:if="{{debugExpanded}}" class="debug-body">
      <view class="debug-row">
        <text class="debug-label">URL:</text>
        <text class="debug-value" selectable="true">{{debugInfo.url || '加载中...'}}</text>
      </view>
      <view class="debug-row">
        <text class="debug-label">Key:</text>
        <text class="debug-value" selectable="true">{{debugInfo.keyPreview || '(空)'}}</text>
      </view>
      <view class="debug-row">
        <text class="debug-label">状态:</text>
        <text class="debug-value status-{{debugInfo.status}}">{{debugInfo.statusLabel || '未测试'}}</text>
      </view>
      <view class="debug-row">
        <text class="debug-label">结果:</text>
        <text class="debug-value" selectable="true">{{debugInfo.message || '点击下方按钮测试'}}</text>
      </view>
      <view class="debug-actions">
        <button class="debug-btn primary" bindtap="onTestApi" loading="{{testing}}">测试 API 连接</button>
        <button class="debug-btn" bindtap="onClearKey">清空 Key</button>
        <button class="debug-btn" bindtap="onChangeKey">修改 Key</button>
      </view>
    </view>
  </view>
</view>
