<view class="container">
  <!-- 顶部蓝色渐变区域 -->
  <view class="header">
    <!-- 标题栏 -->
    <view class="header-top">
      <view class="header-title">个人中心</view>
    </view>

    <!-- 用户信息 -->
    <view class="user-card">
      <view class="avatar" bindtap="{{isLoggedIn ? 'onAvatarTap' : 'onLoginTap'}}">
        <image class="avatar-img" src="{{userInfo.avatar || '/images/avatar-default.svg'}}"></image>
      </view>
      <view class="user-info">
        <block wx:if="{{isLoggedIn}}">
          <view class="user-name">
            <text>{{userInfo.nickname || '用户'}}</text>
            <text class="user-level" wx:if="{{userInfo.level}}">{{userInfo.level}}</text>
          </view>
          <view class="user-tip" wx:if="{{userInfo.phone}}">{{userInfo.phone}}</view>
          <view class="user-tip" wx:else>已登录</view>
        </block>
        <block wx:else>
          <view class="user-name" bindtap="onLoginTap">点击登录</view>
          <view class="user-tip">登录获取更多服务</view>
        </block>
      </view>
      <!-- 右侧：设置 -->
      <view class="user-right">
        <view class="settings-btn" bindtap="onSettingsTap">
          <image class="settings-icon" src="/images/icon-settings.svg"></image>
        </view>
      </view>
    </view>
  </view>

  <!-- 积分卡片（与头部蓝色区域衔接） -->
  <view class="points-card" bindtap="onPointsTap">
    <view class="points-left">
      <view class="points-row">
        <text class="points-label">我的积分</text>
        <text class="points-value">{{points}}</text>
      </view>
      <view class="points-tip">签到可获得积分，积分可兑换服务</view>
    </view>
    <view class="points-btn" catchtap="onSignTap">
      <text>{{signedToday ? '已签到' : '每日签到'}}</text>
    </view>
  </view>

  <!-- 快捷功能 -->
  <view class="quick-actions">
    <view class="action-item" bindtap="onActionTap" data-type="subscription">
      <view class="action-icon-wrap blue">
        <image class="action-icon-img" src="/images/icon-qa-subscription.svg"></image>
      </view>
      <text class="action-text">我的订阅</text>
    </view>
    <view class="action-item" bindtap="onActionTap" data-type="favorite">
      <view class="action-icon-wrap orange">
        <image class="action-icon-img" src="/images/icon-qa-favorite.svg"></image>
      </view>
      <text class="action-text">我的收藏</text>
    </view>
    <view class="action-item" bindtap="onActionTap" data-type="history">
      <view class="action-icon-wrap green">
        <image class="action-icon-img" src="/images/icon-qa-history.svg"></image>
      </view>
      <text class="action-text">浏览历史</text>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="onActionTap" data-type="notification">
      <view class="menu-icon-wrap blue-icon">
        <image class="menu-icon-img" src="/images/icon-message.svg"></image>
      </view>
      <text class="menu-text">消息通知</text>
      <view class="menu-badge" wx:if="{{unreadCount > 0}}">{{unreadCount > 99 ? '99+' : unreadCount}}</view>
      <image class="menu-arrow-img" src="/images/icon-arrow-right.svg"></image>
    </view>
    <view class="menu-item" bindtap="onMenuTap" data-type="orders">
      <view class="menu-icon-wrap blue-icon">
        <image class="menu-icon-img" src="/images/icon-history.svg"></image>
      </view>
      <text class="menu-text">购买记录</text>
      <image class="menu-arrow-img" src="/images/icon-arrow-right.svg"></image>
    </view>
    <view class="menu-item" bindtap="onMenuTap" data-type="points">
      <view class="menu-icon-wrap blue-icon">
        <image class="menu-icon-img" src="/images/icon-points.svg"></image>
      </view>
      <text class="menu-text">积分管理</text>
      <image class="menu-arrow-img" src="/images/icon-arrow-right.svg"></image>
    </view>
    <view class="menu-item" bindtap="onMenuTap" data-type="service">
      <view class="menu-icon-wrap blue-icon">
        <image class="menu-icon-img" src="/images/icon-service.svg"></image>
      </view>
      <text class="menu-text">客服热线</text>
      <text class="menu-extra">400-0931-030</text>
      <image class="menu-arrow-img" src="/images/icon-arrow-right.svg"></image>
    </view>
    <view class="menu-item" bindtap="onMenuTap" data-type="cooperation">
      <view class="menu-icon-wrap blue-icon">
        <image class="menu-icon-img" src="/images/icon-cooperation.svg"></image>
      </view>
      <text class="menu-text">渠道合作</text>
      <image class="menu-arrow-img" src="/images/icon-arrow-right.svg"></image>
    </view>
    <view class="menu-item" bindtap="onMenuTap" data-type="feedback">
      <view class="menu-icon-wrap blue-icon">
        <image class="menu-icon-img" src="/images/icon-feedback.svg"></image>
      </view>
      <text class="menu-text">意见反馈</text>
      <image class="menu-arrow-img" src="/images/icon-arrow-right.svg"></image>
    </view>
  </view>
</view>
