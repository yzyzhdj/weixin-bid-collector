.container {
  padding: 0;
  background: #f1f5f9;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(180deg, #1e88ff 0%, #42a5f5 100%);
  padding: 0 32rpx 40rpx;
  position: relative;
  overflow: hidden;
  /* 兼容 iOS 11.2 以下 */
  padding-top: constant(safe-area-inset-top);
  /* iOS 11.2+ / 安卓全面屏 */
  padding-top: env(safe-area-inset-top);
}

.status-bar {
  width: 100%;
  /* 高度由 JS 动态设置，适配刘海屏 */
}

.header::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle at center, rgba(255, 255, 255, 0.15) 0%, transparent 60%);
  border-radius: 50%;
  pointer-events: none;
}

.header::after {
  content: '';
  position: absolute;
  top: 200rpx;
  left: -50rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle at center, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.top-tabs {
  display: flex;
  justify-content: center;
  gap: 60rpx;
  margin-bottom: 32rpx;
  position: relative;
  z-index: 2;
}

.top-tab {
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 500;
  padding: 0 8rpx 12rpx;
  position: relative;
  letter-spacing: 1rpx;
}

.top-tab.active {
  color: #ffffff;
  font-weight: 700;
}

.top-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #ffffff;
  border-radius: 2rpx;
}

.search-bar {
  background: #ffffff;
  border-radius: 50rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  gap: 16rpx;
  position: relative;
  z-index: 2;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  font-size: 32rpx;
  color: #94a3b8;
  line-height: 1;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #334155;
}

.hot-tags {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 24rpx;
  position: relative;
  z-index: 2;
  flex-wrap: nowrap;
  overflow: hidden;
}

.hot-tag {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 400;
  line-height: 1;
  white-space: nowrap;
}

.hot-tag.fire {
  color: #ffffff;
  font-weight: 600;
}

.hot-tag-divider {
  width: 1rpx;
  height: 24rpx;
  background: rgba(255, 255, 255, 0.4);
}

.hot-tag-refresh {
  font-size: 32rpx;
  color: #ffffff;
  margin-left: auto;
  padding: 0 8rpx;
  line-height: 1;
}

.function-card {
  background: #ffffff;
  margin: -24rpx 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 32rpx 16rpx;
  position: relative;
  z-index: 3;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.function-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx 0;
}

.function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.function-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 10rpx rgba(30, 136, 255, 0.12);
}

.function-icon-img {
  width: 52rpx;
  height: 52rpx;
}

.function-name {
  font-size: 24rpx;
  color: #334155;
}

.promo-banner {
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.promo-left {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.promo-tag {
  background: #ffffff;
  color: #1e88ff;
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 6rpx;
  font-weight: 600;
  flex-shrink: 0;
  border: 1rpx solid #93c5fd;
}

.promo-text {
  font-size: 26rpx;
  color: #1e3a8a;
  font-weight: 500;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.promo-btn {
  background: #ffffff;
  color: #1e88ff;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  font-weight: 500;
  flex-shrink: 0;
  border: 1rpx solid #93c5fd;
}

.stats-card {
  background: #ffffff;
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.stats-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.stats-title-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stats-icon {
  font-size: 28rpx;
  color: #1e88ff;
  line-height: 1;
}

.stats-title {
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 700;
}

.stats-date {
  font-size: 24rpx;
  color: #94a3b8;
  font-weight: 400;
}

.stats-more {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.arrow-right {
  font-size: 28rpx;
  color: #cbd5e1;
  line-height: 1;
}

.stats-table {
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  overflow: hidden;
}

.stats-row {
  display: flex;
  border-bottom: 1rpx solid #e2e8f0;
}

.stats-row:last-child {
  border-bottom: none;
}

.stats-row-header {
  background: #eff6ff;
}

.stats-cell {
  flex: 1;
  text-align: center;
  padding: 18rpx 8rpx;
  font-size: 26rpx;
  color: #475569;
  border-right: 1rpx solid #e2e8f0;
}

.stats-cell:last-child {
  border-right: none;
}

.stats-cell.stats-cell-label {
  background: #eff6ff;
  color: #1e293b;
  font-weight: 600;
  font-size: 26rpx;
}

.stats-row-header .stats-cell {
  color: #1e293b;
  font-weight: 600;
  font-size: 26rpx;
  padding: 20rpx 8rpx;
}

.stats-cell.stats-value {
  color: #1e293b;
  font-weight: 500;
  font-size: 28rpx;
}
