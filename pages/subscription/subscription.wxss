.container {
  padding-bottom: 20rpx;
  background: #f8fafc;
  min-height: 100vh;
  width: 100%;
  overflow-x: hidden;
}

.top-tabs {
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  padding: 24rpx 0;
  width: 100%;
}

.tabs-scroll {
  white-space: nowrap;
  padding: 0 32rpx;
  width: 100%;
}

.top-tab {
  display: inline-block;
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.7);
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 40rpx;
}

.top-tab.active {
  color: #2563eb;
  background: #ffffff;
  font-weight: 600;
}

.filter-bar {
  background: #ffffff;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border-bottom: 1rpx solid #f1f5f9;
  position: relative;
  z-index: 100;
  width: 100%;
  overflow: hidden;
}

.filter-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #475569;
  padding: 12rpx 20rpx;
  background: #f8fafc;
  border-radius: 8rpx;
  transition: all 0.2s;
  flex-shrink: 1;
  overflow: hidden;
  white-space: nowrap;
  min-width: 0;
}

.filter-item text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.filter-item.active {
  color: #2563eb;
  background: #eff6ff;
  border: 1rpx solid #2563eb;
}

.arrow-down {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
  transition: transform 0.2s;
}

.filter-item.active .arrow-down {
  transform: rotate(180deg);
}

.filter-dropdown-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 99;
}

.filter-dropdown {
  position: fixed;
  left: 0;
  right: 0;
  background: #ffffff;
  z-index: 101;
  max-height: 60vh;
  overflow-y: auto;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  animation: slideDown 0.2s ease-out;
}

.region-dropdown {
  overflow: hidden;
}

.region-columns {
  display: flex;
  height: 60vh;
  width: 100%;
}

.region-left {
  width: 240rpx;
  height: 100%;
  background: #f8fafc;
  flex-shrink: 0;
}

.region-province {
  padding: 28rpx 24rpx;
  font-size: 28rpx;
  color: #475569;
  border-bottom: 1rpx solid #f1f5f9;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.region-province.selected {
  background: #ffffff;
  color: #2563eb;
  font-weight: 600;
  position: relative;
}

.region-province.selected::before {
  content: '';
  position: absolute;
  left: 0;
  top: 10%;
  height: 80%;
  width: 6rpx;
  background: #2563eb;
  border-radius: 0 3rpx 3rpx 0;
}

.region-right {
  flex: 1;
  height: 100%;
  min-width: 0;
}

.region-city {
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  color: #334155;
  border-bottom: 1rpx solid #f1f5f9;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.region-city.selected {
  color: #2563eb;
  font-weight: 500;
  background: #eff6ff;
}

@keyframes slideDown {
  from {
    transform: translateY(-20rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.filter-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  color: #334155;
  border-bottom: 1rpx solid #f1f5f9;
}

.filter-option:last-child {
  border-bottom: none;
}

.filter-option.selected {
  color: #2563eb;
  font-weight: 500;
  background: #eff6ff;
}

.check-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.result-info {
  padding: 20rpx 32rpx;
  font-size: 26rpx;
  color: #94a3b8;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.clear-filter {
  color: #2563eb;
  font-size: 26rpx;
  flex-shrink: 0;
}

.bid-list {
  padding: 0 32rpx;
}

.bid-item {
  background: #ffffff;
  padding: 28rpx 32rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.bid-title {
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 500;
  line-height: 1.6;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  word-break: break-all;
}

.bid-info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.bid-type-tag {
  background: #eff6ff;
  color: #1e40af;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  white-space: nowrap;
}

.bid-method-tag {
  background: #fef3c7;
  color: #92400e;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  white-space: nowrap;
}

.bid-meta-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: #94a3b8;
  overflow: hidden;
}

.bid-source {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bid-region {
  flex-shrink: 0;
  white-space: nowrap;
}

.bid-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.bid-budget {
  font-size: 26rpx;
  color: #dc2626;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
  margin-right: 16rpx;
}

.bid-date {
  font-size: 24rpx;
  color: #94a3b8;
  flex-shrink: 0;
  white-space: nowrap;
}

.load-more {
  text-align: center;
  padding: 32rpx;
  color: #94a3b8;
  font-size: 26rpx;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
  color: #94a3b8;
  font-size: 28rpx;
}
