<view class="container">
  <!-- 顶部蓝色区域 -->
  <view class="header">
    <!-- 顶部标签 -->
    <view class="top-tabs">
      <view class="top-tab {{activeType === 'bid' ? 'active' : ''}}" bindtap="switchType" data-type="bid">查标讯</view>
      <view class="top-tab {{activeType === 'company' ? 'active' : ''}}" bindtap="switchType" data-type="company">查企业</view>
    </view>

    <!-- 搜索框 -->
    <view class="search-bar">
      <view class="search-icon">🔍</view>
      <input class="search-input" placeholder="{{searchPlaceholder}}" value="{{searchText}}" bindinput="onInput" bindconfirm="onSearch" confirm-type="search"></input>
    </view>

    <!-- 热门标签 -->
    <view class="hot-tags">
      <view class="hot-tag fire">热搜</view>
      <view class="hot-tag-divider"></view>
      <view class="hot-tag" wx:for="{{hotTags}}" wx:key="index" bindtap="onTagClick" data-keyword="{{item}}">{{item}}</view>
      <view class="hot-tag-refresh" bindtap="onRefreshTags">↻</view>
    </view>
  </view>

  <!-- 功能宫格 (5列) -->
  <view class="function-card">
    <view class="function-grid">
      <view class="function-item" wx:for="{{functionList}}" wx:key="index" bindtap="onFunctionClick" data-type="{{item.type}}">
        <view class="function-icon" style="background: {{item.color}}">
          <image class="function-icon-img" src="{{item.icon}}"></image>
        </view>
        <text class="function-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 找展会 banner -->
  <view class="promo-banner" bindtap="onPromoTap">
    <view class="promo-left">
      <view class="promo-tag">🏛️ 找展会</view>
      <view class="promo-text">一站式查询海量展会信息</view>
    </view>
    <view class="promo-btn">立即查询</view>
  </view>

  <!-- 招标统计 -->
  <view class="stats-card">
    <view class="stats-header">
      <view class="stats-title-wrap">
        <view class="stats-icon">📊</view>
        <text class="stats-title">招标统计</text>
        <text class="stats-date">{{stats.date}}</text>
      </view>
      <view class="stats-more" bindtap="onMoreStats">
        <text>查看更多</text>
        <text class="arrow-right">›</text>
      </view>
    </view>

    <view class="stats-table">
      <view class="stats-row stats-row-header">
        <view class="stats-cell stats-cell-label">全国</view>
        <view class="stats-cell" wx:for="{{stats.columns}}" wx:key="name" wx:for-item="col">{{col.name}}</view>
      </view>
      <view class="stats-row">
        <view class="stats-cell stats-cell-label">今日更新</view>
        <view class="stats-cell stats-value" wx:for="{{stats.today}}" wx:key="*this">{{item}}</view>
      </view>
      <view class="stats-row">
        <view class="stats-cell stats-cell-label">30天累计</view>
        <view class="stats-cell stats-value" wx:for="{{stats.total}}" wx:key="*this">{{item}}</view>
      </view>
    </view>
  </view>
</view>
