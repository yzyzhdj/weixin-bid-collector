<view class="container">
  <!-- 顶部导航 -->
  <view class="header" style="padding-top: {{statusBarHeight}}px;">
    <view class="header-title">订阅</view>
  </view>

  <!-- Tab 切换 -->
  <view class="tabs">
    <view class="tab {{activeTab === 'keyword' ? 'active' : ''}}" bindtap="switchTab" data-tab="keyword">关键词订阅</view>
    <view class="tab {{activeTab === 'company' ? 'active' : ''}}" bindtap="switchTab" data-tab="company">企业订阅</view>
  </view>

  <!-- 企业订阅时间筛选（仅企业订阅时显示） -->
  <view class="time-filter" wx:if="{{activeTab === 'company'}}">
    <view class="time-text" bindtap="showTimeFilter">全部时间 ▾</view>
  </view>

  <!-- 列表 -->
  <view class="list">
    <view wx:if="{{list.length === 0 && !loading}}" class="empty">
      <view class="empty-text">{{activeTab === 'keyword' ? '暂无关键词订阅' : '暂无企业订阅'}}</view>
    </view>

    <!-- 关键词订阅卡片 -->
    <view class="list-item" wx:for="{{list}}" wx:key="id"
          wx:if="{{activeTab === 'keyword'}}"
          data-id="{{item.id}}" data-keywords="{{item.keywords}}" data-name="{{item.name}}" data-index="{{index}}">
      <view class="item-head">
        <image class="item-icon" src="/images/icon-keyword.svg" mode="aspectFit"></image>
        <view class="item-name">{{item.name}}</view>
      </view>
      <view class="item-info">
        <view class="info-row" wx:if="{{item.keywords}}">关键词：{{item.keywords}}</view>
        <view class="info-row">订阅时间：{{item.createTime}}</view>
      </view>
      <view class="item-actions">
        <view class="action-btn" data-id="{{item.id}}" data-keywords="{{item.keywords}}" data-name="{{item.name}}" data-action="view" catchtap="onActionTap">查看详情</view>
        <view class="action-btn" data-id="{{item.id}}" data-action="edit" catchtap="onActionTap">修改</view>
        <view class="action-btn danger" data-id="{{item.id}}" data-action="delete" catchtap="onActionTap">删除</view>
      </view>
    </view>

    <!-- 企业订阅卡片 -->
    <view class="list-item" wx:for="{{list}}" wx:key="id"
          wx:if="{{activeTab === 'company'}}"
          data-id="{{item.id}}" data-name="{{item.companyName}}" data-index="{{index}}">
      <view class="item-head">
        <image class="item-icon" src="/images/icon-company-card.svg" mode="aspectFit"></image>
        <view class="item-name">{{item.companyName}}</view>
        <!-- 标讯总数徽标 -->
        <view class="item-badge" wx:if="{{item.bidCount > 0}}">{{item.bidCount}}</view>
      </view>
      <view class="item-info">
        <view class="info-row" wx:if="{{item.dynamicsText}}">最新：{{item.dynamicsText}}</view>
        <view class="info-row" wx:else>暂无信息更新</view>
      </view>
      <view class="item-actions">
        <view class="action-btn" data-id="{{item.id}}" data-name="{{item.companyName}}" data-action="view" catchtap="onActionTap">查看详情</view>
        <view class="action-btn" data-id="{{item.id}}" data-action="edit" catchtap="onActionTap">修改</view>
        <view class="action-btn danger" data-id="{{item.id}}" data-action="delete" catchtap="onActionTap">删除</view>
      </view>
    </view>
  </view>

  <view class="loading" wx:if="{{loading}}">加载中…</view>

  <!-- 浮动添加按钮 -->
  <view class="fab" bindtap="onAddTap">
    <view class="fab-plus">+</view>
    <view class="fab-label">添加</view>
  </view>
</view>
