<view class="container">
  <view class="header" style="padding-top: {{statusBarHeight}}px;">
    <view class="back-btn" bindtap="onBackTap">‹</view>
    <view class="header-title">{{isEdit ? '编辑订阅' : '添加订阅'}}</view>
  </view>

  <view class="form">
    <!-- 信息标题 -->
    <view class="form-row">
      <view class="form-label">信息标题：</view>
      <input class="form-input" placeholder="请输入"
             data-field="name" value="{{form.name}}" bindinput="onInput" />
    </view>

    <view class="divider"></view>

    <!-- 定制关键词 -->
    <view class="form-block">
      <view class="form-label-block">定制关键词：<text class="form-hint">系统根据关键词查找相关信息</text></view>
      <view class="keyword-add">
        <input class="keyword-input" placeholder="请输入关键词（10字以内）"
               value="{{keywordInput}}" bindinput="onKeywordInput" bindconfirm="onAddKeyword" maxlength="10" />
        <view class="keyword-add-btn {{keywordInput ? 'active' : ''}}" bindtap="onAddKeyword">添加</view>
      </view>
      <view class="keyword-list" wx:if="{{form.keywordList.length > 0}}">
        <view class="keyword-chip" wx:for="{{form.keywordList}}" wx:key="*this"
              data-index="{{index}}" bindtap="onRemoveKeyword">
          {{item}} <text class="chip-x">×</text>
        </view>
      </view>
    </view>

    <view class="divider"></view>

    <!-- 检索模式 -->
    <view class="form-row" bindtap="onPickSearchMode">
      <view class="form-label">检索模式：</view>
      <view class="form-picker">
        <text>{{form.searchModeLabel}}</text>
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="divider"></view>

    <!-- 信息类型 -->
    <view class="form-row" bindtap="onPickBidType">
      <view class="form-label">信息类型：</view>
      <view class="form-picker">
        <text wx:if="{{form.bidTypeLabel}}" class="value">{{form.bidTypeLabel}}</text>
        <text wx:else class="placeholder">请选择</text>
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="divider"></view>

    <!-- 信息地区 -->
    <view class="form-row" bindtap="onPickRegion">
      <view class="form-label">信息地区：</view>
      <view class="form-picker">
        <text wx:if="{{form.regionLabel}}" class="value">{{form.regionLabel}}</text>
        <text wx:else class="placeholder">请选择</text>
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="divider"></view>

    <!-- 开启推送 -->
    <view class="form-row">
      <view class="form-label">开启推送：</view>
      <switch class="form-switch" checked="{{form.notifyEnabled}}"
              bindchange="onToggleSwitch" color="#1e88ff"></switch>
    </view>

    <view class="divider"></view>

    <!-- 推送方式 -->
    <view class="form-block">
      <view class="radio-item" bindtap="onPickPushType" data-type="daily">
        <view class="radio-left">
          <text class="radio-name">每日推送</text>
          <text class="radio-desc">（每天10点、15点、20点分别推送一次信息）</text>
        </view>
        <view class="radio {{form.pushType === 'daily' ? 'checked' : ''}}"></view>
      </view>
      <view class="radio-item" bindtap="onPickPushType" data-type="hourly">
        <view class="radio-left">
          <text class="radio-name">整点推送</text>
          <text class="radio-desc">（每天8点-20点整点实时推送信息）</text>
        </view>
        <view class="radio {{form.pushType === 'hourly' ? 'checked' : ''}}"></view>
      </view>
    </view>
  </view>

  <view class="footer">
    <view class="save-btn {{canSave ? 'active' : 'disabled'}}" bindtap="onSave">保存</view>
  </view>

  <!-- 选择器弹窗 -->
  <view class="modal-mask" wx:if="{{modalShow}}" bindtap="hideModal">
    <view class="modal-panel" catchtap="">
      <view class="modal-title">{{modalTitle}}</view>
      <view class="modal-list">
        <view class="modal-item" wx:for="{{modalOptions}}" wx:key="*this"
              data-value="{{item}}" bindtap="onPickModal">{{item}}</view>
      </view>
      <view class="modal-cancel" bindtap="hideModal">取消</view>
    </view>
  </view>
</view>
