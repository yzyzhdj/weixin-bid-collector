.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}
.header {
  background: linear-gradient(135deg, #1e88ff 0%, #1565c0 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}
.back-btn {
  font-size: 60rpx;
  width: 60rpx;
  line-height: 60rpx;
  text-align: center;
  color: #ffffff;
}
.header-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
}
.add-btn {
  font-size: 26rpx;
  color: #ffffff;
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
}
.list {
  padding: 24rpx;
}
.list-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.item-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.item-switch {
  transform: scale(0.8);
  margin-left: 12rpx;
}
.item-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.tag {
  font-size: 22rpx;
  color: #475569;
  background: #f1f5f9;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
}
.item-foot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1rpx solid #e2e8f0;
  padding-top: 16rpx;
}
.meta-time {
  font-size: 22rpx;
  color: #94a3b8;
}
.delete-btn {
  font-size: 24rpx;
  color: #ef4444;
  padding: 4rpx 12rpx;
}
.empty {
  text-align: center;
  padding: 200rpx 32rpx;
}
.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}
.empty-text {
  font-size: 30rpx;
  color: #475569;
  margin-bottom: 12rpx;
}
.empty-hint {
  font-size: 24rpx;
  color: #94a3b8;
}
.loading {
  text-align: center;
  padding: 32rpx;
  color: #94a3b8;
  font-size: 24rpx;
}
