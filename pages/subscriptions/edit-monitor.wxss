.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 180rpx;
  width: 100%;
  overflow-x: hidden;
}

.header {
  background: #ffffff;
  height: 88rpx;
  display: flex;
  align-items: center;
  position: relative;
  border-bottom: 1rpx solid #f1f5f9;
}

.back-btn {
  position: absolute;
  left: 24rpx;
  font-size: 60rpx;
  width: 60rpx;
  line-height: 60rpx;
  text-align: center;
  color: #1f2937;
}

.header-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2937;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #ffffff;
  gap: 16rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f7fa;
  border-radius: 36rpx;
  padding: 0 20rpx;
  height: 72rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1f2937;
  height: 72rpx;
}

.search-btn {
  font-size: 30rpx;
  color: #1e88ff;
  padding: 0 12rpx;
}

/* 列表 */
.list-section {
  padding: 24rpx;
}

.section-title {
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.company-list {
  background: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
}

.company-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.company-item:last-child {
  border-bottom: none;
}

.company-item.selected {
  background: #f0f7ff;
}

.company-name {
  flex: 1;
  font-size: 28rpx;
  color: #1e88ff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 0;
}

.company-name .hl {
  color: #ef4444;
  font-weight: 600;
}

.check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #cbd5e1;
  flex-shrink: 0;
  position: relative;
}

.check.checked {
  background: #1e88ff;
  border-color: #1e88ff;
}

.check.checked::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 12rpx;
  height: 6rpx;
  border-left: 3rpx solid #fff;
  border-bottom: 3rpx solid #fff;
  transform: translate(-50%, -70%) rotate(-45deg);
}

.loading,
.empty {
  text-align: center;
  padding: 60rpx 32rpx;
  color: #94a3b8;
  font-size: 26rpx;
}

/* 底部按钮 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.confirm-btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 8rpx;
  font-size: 32rpx;
  color: #ffffff;
  background: #93c5fd;
}

.confirm-btn.active {
  background: #1e88ff;
}

.confirm-btn.disabled {
  background: #93c5fd;
}
