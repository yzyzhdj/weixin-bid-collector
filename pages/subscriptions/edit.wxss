.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 180rpx;
  width: 100%;
  overflow-x: hidden;
}

.header {
  background: #ffffff;
  height: 88rpx;
  display: flex;
  align-items: center;
  position: relative;
  border-bottom: 1rpx solid #f1f5f9;
}

.back-btn {
  position: absolute;
  left: 24rpx;
  font-size: 60rpx;
  width: 60rpx;
  line-height: 60rpx;
  text-align: center;
  color: #1f2937;
}

.header-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2937;
}

.form {
  background: #ffffff;
  margin-top: 20rpx;
}

.form-row {
  display: flex;
  align-items: center;
  min-height: 96rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
}

.form-label {
  width: 180rpx;
  font-size: 30rpx;
  color: #1f2937;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  color: #1f2937;
  min-width: 0;
}

.form-picker {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 30rpx;
  color: #1f2937;
  min-width: 0;
}

.form-picker .placeholder {
  color: #cbd5e1;
}

.form-picker .arrow {
  color: #cbd5e1;
  font-size: 36rpx;
  margin-left: 8rpx;
}

.form-switch {
  transform: scale(0.8);
  margin-left: auto;
}

.divider {
  height: 1rpx;
  background: #f1f5f9;
  margin-left: 24rpx;
}

.form-block {
  padding: 20rpx 24rpx;
  box-sizing: border-box;
}

.form-label-block {
  font-size: 30rpx;
  color: #1f2937;
  margin-bottom: 16rpx;
}

.form-hint {
  font-size: 24rpx;
  color: #94a3b8;
  font-weight: 400;
}

.keyword-add {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.keyword-input {
  flex: 1;
  background: #f1f5f9;
  border-radius: 8rpx;
  padding: 0 20rpx;
  height: 72rpx;
  font-size: 28rpx;
  color: #1f2937;
  min-width: 0;
}

.keyword-add-btn {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background: #93c5fd;
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 8rpx;
}

.keyword-add-btn.active {
  background: #1e88ff;
}

.keyword-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.keyword-chip {
  background: #eff6ff;
  color: #1e88ff;
  font-size: 26rpx;
  padding: 8rpx 20rpx;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.chip-x {
  font-size: 28rpx;
  color: #94a3b8;
  line-height: 1;
}

/* 推送方式 */
.radio-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
}

.radio-left {
  flex: 1;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  min-width: 0;
}

.radio-name {
  font-size: 30rpx;
  color: #1f2937;
  margin-right: 12rpx;
}

.radio-desc {
  font-size: 24rpx;
  color: #94a3b8;
}

.radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #cbd5e1;
  flex-shrink: 0;
  position: relative;
  background: #ffffff;
}

.radio.checked {
  border-color: #1e88ff;
}

.radio.checked::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #1e88ff;
  transform: translate(-50%, -50%);
}

/* 底部 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.save-btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 8rpx;
  font-size: 32rpx;
  color: #ffffff;
  background: #93c5fd;
}

.save-btn.active {
  background: #1e88ff;
}

.save-btn.disabled {
  background: #93c5fd;
}

/* Modal */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-panel {
  width: 100%;
  background: #ffffff;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  padding-bottom: env(safe-area-inset-bottom);
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.modal-title {
  text-align: center;
  font-size: 30rpx;
  color: #1f2937;
  font-weight: 600;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.modal-list {
  flex: 1;
  overflow-y: auto;
  padding: 12rpx 0;
}

.modal-item {
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: #1f2937;
  border-bottom: 1rpx solid #f5f7fa;
}

.modal-cancel {
  text-align: center;
  padding: 24rpx;
  font-size: 30rpx;
  color: #ef4444;
  background: #ffffff;
  border-top: 12rpx solid #f5f7fa;
}
