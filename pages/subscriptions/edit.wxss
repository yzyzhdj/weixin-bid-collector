.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}
.header {
  background: linear-gradient(135deg, #1e88ff 0%, #1565c0 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}
.back-btn {
  font-size: 60rpx;
  width: 60rpx;
  line-height: 60rpx;
  text-align: center;
  color: #ffffff;
}
.header-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  margin-right: 60rpx;
}
.form {
  background: #ffffff;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 0 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}
.form-item:last-of-type {
  border-bottom: 0;
}
.form-label {
  width: 180rpx;
  font-size: 28rpx;
  color: #475569;
}
.form-label.required::before {
  content: '*';
  color: #ef4444;
  margin-right: 4rpx;
}
.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #1e293b;
}
.form-picker {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #1e293b;
}
.form-picker .placeholder {
  color: #94a3b8;
}
.form-picker .arrow {
  color: #94a3b8;
  font-size: 32rpx;
}
.form-budget {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.budget-input {
  flex: 1;
  background: #f8fafc;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
}
.dash {
  color: #94a3b8;
}
.form-switch {
  transform: scale(0.9);
}
.save-btn {
  margin: 48rpx 24rpx 0;
  background: linear-gradient(135deg, #1e88ff 0%, #1565c0 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 12rpx;
}
.save-btn[disabled] {
  background: #94a3b8;
  color: #ffffff;
}
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}
.modal-panel {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 0 0;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}
.modal-title {
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  padding: 0 0 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
}
.modal-list {
  flex: 1;
  overflow-y: auto;
  padding: 16rpx 0;
}
.modal-item {
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  color: #334155;
  border-bottom: 1rpx solid #f8fafc;
}
.modal-cancel {
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
  color: #64748b;
  border-top: 1rpx solid #f1f5f9;
}
