<view class="container">
  <!-- 顶部深色区域 -->
  <view class="header">
    <!-- 状态栏占位（适配刘海屏） -->
    <view class="status-bar" style="height: {{statusBarHeight}}px"></view>

    <view class="header-top">
      <view class="back-btn" bindtap="onBack">‹</view>
      <view class="header-title">会员中心</view>
    </view>
  </view>

  <!-- 会员卡片 -->
  <view class="vip-card">
    <view class="vip-avatar">
      <text class="avatar-emoji">👨‍💼</text>
    </view>
    <view class="vip-info">
      <view class="vip-phone">15117088876</view>
      <view class="vip-type">普通用户</view>
    </view>
    <view class="vip-medal">⭐</view>
  </view>

  <!-- 类型切换 -->
  <view class="type-tabs">
    <view class="type-tab {{memberType === 'personal' ? 'active' : ''}}" bindtap="switchMemberType" data-type="personal">个人会员</view>
    <view class="type-tab {{memberType === 'enterprise' ? 'active' : ''}}" bindtap="switchMemberType" data-type="enterprise">企业会员</view>
  </view>

  <!-- 套餐选择 -->
  <view class="plan-list">
    <view class="plan-card {{selectedPlan === index ? 'selected' : ''}}" wx:for="{{plans}}" wx:key="index" bindtap="selectPlan" data-index="{{index}}">
      <view class="plan-name">{{item.name}}</view>
      <view class="plan-price">
        <text class="price-currency">¥</text>
        <text class="price-value">{{item.price}}</text>
      </view>
      <view class="plan-original">¥{{item.original}}</view>
      <view class="plan-save">立省{{item.save}}元</view>
    </view>
  </view>

  <!-- 会员权益 -->
  <view class="benefit-section">
    <view class="benefit-title-wrap">
      <view class="benefit-line"></view>
      <view class="benefit-title">会员权益</view>
      <view class="benefit-line"></view>
    </view>
    <view class="benefit-grid">
      <view class="benefit-item" wx:for="{{benefits}}" wx:key="index">
        <view class="benefit-icon">
          <text class="benefit-emoji">{{item.emoji}}</text>
        </view>
        <text class="benefit-text">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 底部说明 -->
  <view class="note">
    <text class="note-text">注：会员开通后不支持退款，请试用后再购买，谢谢~（每天有3</text>
  </view>

  <!-- 底部支付栏 -->
  <view class="bottom-bar">
    <view class="total-info">
      <view class="total-row">
        <text class="total-label">合计：</text>
        <text class="total-currency">¥</text>
        <text class="total-price">{{plans[selectedPlan].price}}</text>
      </view>
      <view class="save-info">
        <text>已减{{plans[selectedPlan].save}}元</text>
        <text class="save-detail">优惠明细 ⌄</text>
      </view>
    </view>
    <view class="pay-btn" bindtap="onPay">立即支付</view>
  </view>
</view>
