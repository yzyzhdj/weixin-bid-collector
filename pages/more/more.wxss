.container {
  padding: 0;
  background: #f1f5f9;
  min-height: 100vh;
  padding-bottom: 200rpx;
}

.header {
  background: #0f172a;
  padding: 0 32rpx 100rpx;
  position: relative;
  /* 兼容 iOS 11.2 以下 */
  padding-top: constant(safe-area-inset-top);
  /* iOS 11.2+ / 安卓全面屏 */
  padding-top: env(safe-area-inset-top);
}

.status-bar {
  width: 100%;
  /* 高度由 JS 动态设置，适配刘海屏 */
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 60rpx;
  position: relative;
  z-index: 2;
}

.back-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #ffffff;
  font-weight: 300;
  line-height: 1;
}

.header-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  color: #ffffff;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.vip-card {
  margin: -80rpx 24rpx 0;
  background: linear-gradient(135deg, #fcd34d 0%, #f59e0b 50%, #d97706 100%);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  position: relative;
  z-index: 3;
  box-shadow: 0 8rpx 24rpx rgba(245, 158, 11, 0.3);
  overflow: hidden;
}

.vip-card::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 200rpx;
  height: 100%;
  background: radial-gradient(circle at right, rgba(255, 255, 255, 0.2) 0%, transparent 60%);
  pointer-events: none;
}

.vip-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 4rpx solid #ffffff;
}

.avatar-emoji {
  font-size: 50rpx;
  line-height: 1;
}

.vip-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  z-index: 1;
}

.vip-phone {
  font-size: 32rpx;
  color: #1e293b;
  font-weight: 600;
}

.vip-type {
  font-size: 24rpx;
  color: rgba(30, 41, 59, 0.7);
}

.vip-medal {
  font-size: 60rpx;
  z-index: 1;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.2));
}

.type-tabs {
  display: flex;
  background: #ffffff;
  margin: 24rpx 24rpx 0;
  border-radius: 20rpx 20rpx 0 0;
  padding: 16rpx 16rpx 0;
  gap: 16rpx;
}

.type-tab {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  color: #64748b;
  padding: 24rpx 0;
  font-weight: 500;
  border-radius: 12rpx 12rpx 0 0;
  position: relative;
}

.type-tab.active {
  color: #1e293b;
  font-weight: 700;
  background: #f8fafc;
}

.type-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: transparent;
}

.plan-list {
  display: flex;
  background: #f8fafc;
  margin: 0 24rpx;
  padding: 32rpx 16rpx;
  gap: 16rpx;
}

.plan-card {
  flex: 1;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  border: 2rpx solid #e2e8f0;
  position: relative;
}

.plan-card.selected {
  background: #fffbeb;
  border-color: #f59e0b;
  box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.15);
}

.plan-name {
  font-size: 24rpx;
  color: #1e293b;
  font-weight: 600;
}

.plan-price {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
  color: #d97706;
}

.price-currency {
  font-size: 24rpx;
  font-weight: 600;
}

.price-value {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1;
}

.plan-original {
  font-size: 22rpx;
  color: #94a3b8;
  text-decoration: line-through;
}

.plan-save {
  font-size: 22rpx;
  color: #d97706;
  background: #fef3c7;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.benefit-section {
  background: #ffffff;
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 32rpx;
}

.benefit-title-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.benefit-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, #cbd5e1 50%, transparent 100%);
}

.benefit-title {
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.benefit-title::before,
.benefit-title::after {
  content: '≣';
  color: #94a3b8;
  font-size: 24rpx;
}

.benefit-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32rpx 16rpx;
}

.benefit-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.benefit-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.benefit-emoji {
  font-size: 44rpx;
  line-height: 1;
  color: #d97706;
}

.benefit-text {
  font-size: 24rpx;
  color: #475569;
  text-align: center;
}

.note {
  padding: 0 32rpx 24rpx;
}

.note-text {
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.5;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(90deg, #1e293b 0%, #0f172a 100%);
  padding: 20rpx 32rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 10;
}

.total-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
}

.total-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  color: #ffffff;
}

.total-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.total-currency {
  font-size: 24rpx;
  color: #fbbf24;
  font-weight: 600;
}

.total-price {
  font-size: 40rpx;
  color: #fbbf24;
  font-weight: 700;
  line-height: 1;
}

.save-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.save-detail {
  color: rgba(255, 255, 255, 0.7);
}

.pay-btn {
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  color: #ffffff;
  font-size: 30rpx;
  padding: 24rpx 56rpx;
  border-radius: 40rpx;
  font-weight: 700;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.4);
}
