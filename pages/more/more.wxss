.container {
  padding: 32rpx;
  padding-bottom: 40rpx;
  background: #f8fafc;
  min-height: 100vh;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 24rpx;
  padding-left: 8rpx;
}

.grid-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
  margin-bottom: 48rpx;
}

.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.item-icon {
  width: 112rpx;
  height: 112rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.icon-img {
  width: 56rpx;
  height: 56rpx;
}

.badge {
  position: absolute;
  top: -8rpx;
  right: -16rpx;
  background: #dc2626;
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}

.item-name {
  font-size: 24rpx;
  color: #334155;
  text-align: center;
  line-height: 1.3;
}
