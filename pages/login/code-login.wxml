<view class="container">
  <!-- 自定义顶部 -->
  <view class="custom-header" style="padding-top: {{statusBarHeight}}px;">
    <view class="header-row" style="height: {{headerContentHeight}}px;">
      <view class="back-btn" bindtap="onBackTap">
        <text class="back-icon">‹</text>
      </view>
      <view class="header-center">
        <text class="header-title">注册/登录</text>
      </view>
      <view class="header-placeholder"></view>
    </view>
  </view>

  <!-- 主体内容 -->
  <view class="content">
    <!-- Logo 区域 -->
    <view class="logo-section">
      <image class="brand-logo" src="/images/logo-sun.svg"></image>
      <view class="brand-text">
        <text class="brand-name">阳光标讯</text>
        <text class="brand-url">www.sunbidinfo.com</text>
      </view>
    </view>

    <!-- 表单区域 -->
    <view class="form-section">
      <!-- 手机号输入 -->
      <view class="input-row">
        <input
          class="input-field"
          type="number"
          maxlength="11"
          placeholder="请输入手机号"
          placeholder-class="input-placeholder"
          value="{{phone}}"
          bindinput="onPhoneInput"
        />
      </view>

      <!-- 验证码输入 + 获取按钮 -->
      <view class="input-row code-row">
        <input
          class="input-field code-input"
          type="number"
          maxlength="6"
          placeholder="请输入验证码"
          placeholder-class="input-placeholder"
          value="{{code}}"
          bindinput="onCodeInput"
        />
        <view class="send-code-btn {{sending ? 'sending' : ''}} {{countdown > 0 ? 'disabled' : ''}}"
              bindtap="onSendCode">
          <text class="send-code-text">{{countdown > 0 ? countdown + 's' : '获取验证码'}}</text>
        </view>
      </view>

      <!-- 立即登录按钮 -->
      <button
        class="login-btn {{agreed && phone && code ? 'active' : 'disabled'}}"
        bindtap="onLoginTap"
        disabled="{{!agreed || !phone || !code || logging}}"
        hover-class="none"
      >
        <text class="login-btn-text">{{logging ? '登录中...' : '立即登录'}}</text>
      </button>

      <!-- 协议勾选 -->
      <view class="agreement" bindtap="onToggleAgreement">
        <view class="checkbox {{agreed ? 'checked' : ''}}">
          <text wx:if="{{agreed}}" class="checkbox-tick">✓</text>
        </view>
        <view class="agreement-text">
          <text>已阅读并同意</text>
          <text class="agreement-link" catchtap="onOpenAgreement" data-type="user">《用户协议》</text>
          <text>与</text>
          <text class="agreement-link" catchtap="onOpenAgreement" data-type="privacy">《隐私政策》</text>
        </view>
      </view>
    </view>

    <!-- 手机号快捷登录入口 -->
    <view class="quick-login" bindtap="onQuickLogin">
      <text class="quick-login-text">手机号快捷登录</text>
    </view>
  </view>
</view>
