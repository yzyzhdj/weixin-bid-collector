<view class="container">
  <!-- 顶部统计 -->
  <view class="stats-bar">
    <text class="stats-num">{{favorites.length}}</text>
    <text class="stats-label">条收藏</text>
    <view class="stats-clear" bindtap="onClearAll" wx:if="{{favorites.length > 0}}">
      <text>清空</text>
    </view>
  </view>

  <!-- 列表 -->
  <view class="list" wx:if="{{favorites.length > 0}}">
    <view class="item" wx:for="{{favorites}}" wx:key="bidId" bindtap="onItemTap" data-id="{{item.bidId}}">
      <view class="item-main">
        <view class="item-title">{{item.title || '招标信息'}}</view>
        <view class="item-meta">
          <view class="tag tag-blue" wx:if="{{item.bidType}}">{{item.bidType}}</view>
          <view class="tag tag-gray" wx:if="{{item.province}}">{{item.province}}{{item.city ? '·' + item.city : ''}}</view>
        </view>
        <view class="item-time">{{item.timeText}}</view>
      </view>
      <view class="item-action" catchtap="onRemoveTap" data-id="{{item.bidId}}">
        <text class="item-remove">×</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:else>
    <view class="empty-icon">
      <text>♡</text>
    </view>
    <view class="empty-title">还没有收藏任何招标</view>
    <view class="empty-sub">去首页查看感兴趣的招标信息吧</view>
    <view class="empty-btn" bindtap="onGoHome">去首页</view>
  </view>
</view>
