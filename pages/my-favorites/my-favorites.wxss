.container {
  min-height: 100vh;
  background: #f8fafc;
  padding-bottom: 40rpx;
}

.stats-bar {
  display: flex;
  align-items: baseline;
  padding: 32rpx 24rpx 24rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f1f5f9;
}

.stats-num {
  font-size: 48rpx;
  font-weight: 600;
  color: #1e88ff;
  margin-right: 8rpx;
}

.stats-label {
  font-size: 26rpx;
  color: #64748b;
  flex: 1;
}

.stats-clear {
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  color: #ef4444;
  background: #fef2f2;
  border-radius: 24rpx;
}

.list {
  padding: 24rpx;
}

.item {
  display: flex;
  align-items: flex-start;
  background: #ffffff;
  padding: 28rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.item-main { flex: 1; }

.item-title {
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 500;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
}

.tag-blue { background: #eff6ff; color: #1e88ff; }
.tag-gray { background: #f1f5f9; color: #475569; }

.item-time {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.item-action {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
}

.item-remove {
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  font-size: 36rpx;
  color: #cbd5e1;
  background: #f1f5f9;
  border-radius: 50%;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 48rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 96rpx;
  color: #cbd5e1;
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #475569;
  font-weight: 500;
}

.empty-sub {
  font-size: 26rpx;
  color: #94a3b8;
  margin-top: 12rpx;
}

.empty-btn {
  margin-top: 48rpx;
  padding: 20rpx 64rpx;
  background: #1e88ff;
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 48rpx;
  box-shadow: 0 4rpx 12rpx rgba(30, 136, 255, 0.3);
}
