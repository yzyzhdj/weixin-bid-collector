.page {
  min-height: 100vh;
  background: #f1f5f9;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(180deg, #1e88ff 0%, #42a5f5 100%);
  padding: 24rpx 32rpx 28rpx;
}

.header-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.4;
  text-align: center;
}

.header-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  text-align: center;
}

.list {
  padding: 24rpx;
}

.bid-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.bid-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.bid-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.bid-buyer {
  font-size: 24rpx;
  color: #64748b;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bid-date {
  font-size: 22rpx;
  color: #94a3b8;
  flex-shrink: 0;
}

.bid-budget {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #1e88ff;
}

.load-tip {
  padding: 32rpx 0;
  text-align: center;
  color: #94a3b8;
  font-size: 24rpx;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
  color: #94a3b8;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #94a3b8;
  font-size: 28rpx;
}
