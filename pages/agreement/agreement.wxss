.container {
  min-height: 100vh;
  background: #f8fafc;
  display: flex;
  flex-direction: column;
}

/* ========== 自定义顶部 ========== */
.custom-header {
  background: #ffffff;
  width: 100%;
  border-bottom: 1rpx solid #e2e8f0;
}

.header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  position: relative;
}

.back-btn {
  width: 60rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  flex-shrink: 0;
}

.back-icon {
  font-size: 56rpx;
  color: #1e293b;
  line-height: 1;
  font-weight: 300;
}

.header-center {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
}

.header-title {
  font-size: 32rpx;
  color: #1e293b;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.header-placeholder {
  width: 60rpx;
  flex-shrink: 0;
}

/* ========== 内容滚动区 ========== */
.content-scroll {
  flex: 1;
  height: 0;
}

.content {
  padding: 32rpx 32rpx 80rpx;
}

/* 文档头部 */
.doc-header {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.doc-title {
  font-size: 36rpx;
  color: #1e293b;
  font-weight: 700;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

.doc-meta {
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.6;
}

/* 文档正文 */
.doc-body {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.section {
  margin-bottom: 32rpx;
}

.section:last-child {
  margin-bottom: 0;
}

.section-title {
  display: block;
  font-size: 30rpx;
  color: #1e88ff;
  font-weight: 600;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.section-content {
  display: block;
  font-size: 28rpx;
  color: #334155;
  line-height: 1.85;
  text-align: justify;
}

/* 列表项 */
.list-item {
  display: flex;
  margin-bottom: 12rpx;
  padding-left: 8rpx;
}

.list-marker {
  font-size: 28rpx;
  color: #1e88ff;
  font-weight: 600;
  margin-right: 8rpx;
  flex-shrink: 0;
  min-width: 36rpx;
}

.list-text {
  flex: 1;
  font-size: 28rpx;
  color: #334155;
  line-height: 1.85;
  text-align: justify;
}

/* 子段落 */
.sub-section {
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 4rpx solid #dbeafe;
}

.sub-section:last-child {
  margin-bottom: 0;
}

.sub-title {
  display: block;
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.sub-content {
  display: block;
  font-size: 26rpx;
  color: #475569;
  line-height: 1.85;
  text-align: justify;
}

/* 页脚 */
.doc-footer {
  text-align: center;
  padding: 32rpx 0 16rpx;
  color: #94a3b8;
  font-size: 22rpx;
  letter-spacing: 1rpx;
}
