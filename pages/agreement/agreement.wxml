<view class="container">
  <!-- 自定义顶部 -->
  <view class="custom-header" style="padding-top: {{statusBarHeight}}px;">
    <view class="header-row" style="height: {{headerContentHeight}}px;">
      <view class="back-btn" bindtap="onBackTap">
        <text class="back-icon">‹</text>
      </view>
      <view class="header-center">
        <text class="header-title">{{title}}</text>
      </view>
      <view class="header-placeholder"></view>
    </view>
  </view>

  <!-- 协议内容（scroll-view 用 fixed 高度确保真机可见）-->
  <scroll-view class="content-scroll" scroll-y="{{true}}" enable-flex="{{true}}">
    <view class="content">
      <!-- 标题区 -->
      <view class="doc-header">
        <text class="doc-title">{{title}}</text>
        <text class="doc-meta">应用名称：{{appName}}</text>
        <text class="doc-meta">应用主体：{{company}}</text>
        <text class="doc-meta">生效日期：{{effectiveDate}}</text>
        <text class="doc-meta">更新日期：{{updateDate}}</text>
      </view>

      <!-- 协议正文（动态内容）-->
      <view class="doc-body">
        <block wx:for="{{sections}}" wx:key="title" wx:for-item="section">
          <view class="section">
            <text class="section-title">{{section.title}}</text>

            <!-- 普通段落 -->
            <text wx:if="{{section.hasContent}}" class="section-content">{{section.content}}</text>

            <!-- 列表段落（已预处理 marker/text） -->
            <view wx:if="{{section.hasItems}}" class="list-block">
              <view wx:for="{{section.items}}" wx:key="index" wx:for-item="item" class="list-item">
                <text wx:if="{{item.marker}}" class="list-marker">{{item.marker}}</text>
                <text class="list-text">{{item.text}}</text>
              </view>
            </view>

            <!-- 子段落 -->
            <view wx:if="{{section.hasSubs}}" class="subs-block">
              <view wx:for="{{section.subs}}" wx:key="title" wx:for-item="sub" class="sub-section">
                <text class="sub-title">{{sub.title}}</text>
                <text class="sub-content">{{sub.content}}</text>
              </view>
            </view>
          </view>
        </block>
      </view>

      <!-- 页脚 -->
      <view class="doc-footer">
        <text>— 本协议最终解释权归{{company}}所有 —</text>
      </view>
    </view>
  </scroll-view>
</view>
