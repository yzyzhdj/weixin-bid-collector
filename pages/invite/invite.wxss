.page {
  min-height: 100vh;
  background: #f1f5f9;
  padding-bottom: 40rpx;
}

.hero {
  background: linear-gradient(135deg, #f97316 0%, #fb923c 100%);
  padding: 60rpx 32rpx 40rpx;
  position: relative;
  overflow: hidden;
}

.hero-decor-1 {
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 240rpx;
  height: 240rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.2) 0%, transparent 70%);
  border-radius: 50%;
}

.hero-decor-2 {
  position: absolute;
  bottom: -40rpx;
  left: -40rpx;
  width: 180rpx;
  height: 180rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  text-align: center;
  position: relative;
  z-index: 1;
}

.hero-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  text-align: center;
  margin-top: 16rpx;
  position: relative;
  z-index: 1;
}

.hero-stats {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 40rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 24rpx 0;
  position: relative;
  z-index: 1;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  margin: 24rpx 24rpx 0;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 24rpx;
}

.code-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f8fafc;
  border: 2rpx dashed #1e88ff;
  border-radius: 12rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
}

.code-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e88ff;
  letter-spacing: 4rpx;
  font-family: 'Courier New', monospace;
}

.code-copy {
  background: #1e88ff;
  color: #ffffff;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
}

.code-link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f1f5f9;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 24rpx;
}

.link-text {
  flex: 1;
  font-size: 24rpx;
  color: #475569;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.link-action {
  font-size: 24rpx;
  color: #1e88ff;
  font-weight: 600;
  flex-shrink: 0;
}

.share-btn {
  background: linear-gradient(135deg, #1e88ff 0%, #42a5f5 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
}

.rule-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.rule-item:last-child {
  margin-bottom: 0;
}

.rule-num {
  width: 40rpx;
  height: 40rpx;
  background: #1e88ff;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.rule-text {
  flex: 1;
  font-size: 26rpx;
  color: #475569;
  line-height: 1.5;
}

.record {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.record:last-child {
  border-bottom: none;
}

.record-avatar {
  width: 64rpx;
  height: 64rpx;
  background: #f1f5f9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
  overflow: hidden;
}

.record-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.record-info {
  flex: 1;
  min-width: 0;
}

.record-name {
  font-size: 28rpx;
  color: #0f172a;
  font-weight: 500;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-meta {
  font-size: 22rpx;
  color: #94a3b8;
}

.record-right {
  text-align: right;
  flex-shrink: 0;
}

.record-status {
  font-size: 24rpx;
  font-weight: 500;
}

.record-reward {
  font-size: 22rpx;
  color: #10b981;
  margin-top: 4rpx;
}

.empty {
  text-align: center;
  padding: 40rpx 0;
  color: #94a3b8;
  font-size: 26rpx;
}
